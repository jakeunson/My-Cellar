    replacement_chunks {
      replacement_content: "import { ComposeFile } from \'../types\';\n\nexport const composeTemplates: ComposeFile[] = [\n  {\n    name: \"TastingModels.kt\",\n    path: \"app/src/main/java/com/example/tastingjournal/data/TastingModels.kt\",\n    language: \"kotlin\",\n    description: \"\355\205\214\354\235\264\354\212\244\355\214\205 \352\270\260\353\241\235\354\235\204 \354\234\204\355\225\234 \355\225\265\354\213\254 \353\215\260\354\235\264\355\204\260 \355\201\264\353\236\230\354\212\244, \354\271\264\355\205\214\352\263\240\353\246\254 \354\227\264\352\261\260\355\230\225 \353\260\217 \354\203\230\355\224\214 \353\215\224\353\257\270 \353\215\260\354\235\264\355\204\260 \354\240\225\354\235\230\",\n    code: `package com.example.tastingjournal.data\n\nimport java.util.UUID\n\nenum class LiquorCategory(val displayName: String, val icon: String) {\n    WHISKEY(\"\354\234\204\354\212\244\355\202\244\", \"\360\237\245\203\"),\n    WINE(\"\354\231\200\354\235\270\", \"\360\237\215\267\"),\n    BEER(\"\353\247\245\354\243\274\", \"\360\237\215\272\"),\n    SAKE(\"\354\202\254\354\274\200\", \"\360\237\215\266\"),\n    KOREAN(\"\354\240\204\355\206\265\354\243\274\", \"\360\237\215\266\"),\n    COCKTAIL(\"\354\271\265\355\205\214\354\235\274\", \"\360\237\215\270\"),\n    OTHER(\"\352\270\260\355\203\200\", \"\360\237\215\271\")\n}\n\ndata class FlavorProfile(\n    val sweet: Int = 0,  // \353\213\250\353\247\233 (0-5)\n    val bitter: Int = 0, // \354\223\264\353\247\233 (0-5)\n    val sour: Int = 0,   // \354\213\240\353\247\233 (0-5)\n    val body: Int = 0,   // \353\260\224\353\224\224\352\260\220 (0-5)\n    val smoky: Int = 0   // \354\212\244\353\252\250\355\202\244\355\225\250 (0-5)\n)\n\ndata class TastingEntry(\n    val id: String = UUID.randomUUID().toString(),\n    val name: String,\n    val category: LiquorCategory,\n    val abv: Float, // \354\225\214\354\275\224\354\230\254 \353\217\204\354\210\230 (%)\n    val rating: Int, // \353\263\204\354\240\220 (1-5)\n    val date: String, // \354\236\221\354\204\261\354\235\274 (YYYY-MM-DD)\n    val notes: String, // \355\205\214\354\235\264\354\212\244\355\214\205 \353\205\270\355\212\270 \353\251\224\353\252\250\n    val flavors: FlavorProfile = FlavorProfile()\n)\n\nobject DummyData {\n    val sampleTastings = listOf(\n        TastingEntry(\n            name = \"\353\247\245\354\272\230\353\236\200 12\353\205\204 \354\205\260\353\246\254 \354\230\244\355\201\254\",\n            category = LiquorCategory.WHISKEY,\n            abv = 40.0f,\n            rating = 5,\n            date = \"2026-06-25\",\n            notes = \"\354\205\260\353\246\254 \354\230\244\355\201\254 \355\212\271\354\234\240\354\235\230 \355\222\215\353\266\200\355\225\234 \353\247\220\353\246\260 \352\263\274\354\235\274 \355\226\245\352\263\274 \353\213\254\354\275\244\355\225\234 \354\271\264\353\235\274\353\251\234, \354\213\234\353\202\230\353\252\254 \354\212\244\355\214\214\354\235\264\354\212\244\352\260\200 \354\241\260\355\231\224\353\241\255\352\263\240 \353\266\200\353\223\234\353\237\254\354\232\264 \355\224\274\353\213\210\354\213\234\353\245\274 \353\263\264\354\227\254\354\244\214.\",\n            flavors = FlavorProfile(sweet = 4, bitter = 2, sour = 1, body = 4, smoky = 2)\n        ),\n        TastingEntry(\n            name = \"\354\203\244\355\206\240 \353\247\210\352\263\240 2018\",\n            category = LiquorCategory.WINE,\n            abv = 13.5f,\n            rating = 5,\n            date = \"2026-06-20\",\n            notes = \"\354\247\231\354\235\200 \353\243\250\353\271\204\354\203\211. \353\270\224\353\236\231\353\262\240\353\246\254, \354\240\234\353\271\204\352\275\203, \355\235\231 \353\202\264\354\235\214\354\235\264 \354\226\264\354\232\260\353\237\254\354\247\200\353\251\260 \354\213\244\355\201\254\354\262\230\353\237\274 \353\266\200\353\223\234\353\237\254\354\232\264 \355\203\200\353\213\214\352\263\274 \354\232\260\354\225\204\355\225\230\352\263\240 \352\270\264 \354\227\254\354\232\264\354\235\204 \353\202\250\352\271\200.\",\n            flavors = FlavorProfile(sweet = 1, bitter = 3, sour = 4, body = 5, smoky = 1)\n        ),\n        TastingEntry(\n            name = \"\354\240\234\354\243\274 \355\216\240\353\241\261 \354\227\220\354\235\274\",\n            category = LiquorCategory.BEER,\n            abv = 5.5f,\n            rating = 4,\n            date = \"2026-06-28\",\n            notes = \"\354\213\234\355\212\270\353\237\254\354\212\244\355\225\234 \355\231\211\354\235\230 \355\226\245\354\235\264 \354\213\240\354\204\240\355\225\230\352\262\214 \355\215\274\354\247\200\353\251\260, \352\260\200\353\263\215\352\263\240 \354\262\255\353\237\211\352\260\220 \353\204\230\354\271\230\352\262\214 \354\246\220\352\270\270 \354\210\230 \354\236\210\353\212\224 \355\216\230\354\235\274 \354\227\220\354\235\274.\",\n            flavors = FlavorProfile(sweet = 2, bitter = 3, sour = 2, body = 2, smoky = 0)\n        ),\n        TastingEntry(\n            name = \"\355\231\224\354\232\224 25\",\n            category = LiquorCategory.KOREAN,\n            abv = 25.0f,\n            rating = 4,\n            date = \"2026-06-15\",\n            notes = \"\354\214\200 \355\212\271\354\234\240\354\235\230 \354\235\200\354\235\200\355\225\234 \355\226\245\352\263\274 \353\266\200\353\223\234\353\237\275\352\263\240 \352\271\224\353\201\224\355\225\234 \353\252\251\353\204\230\352\271\200. \354\226\274\354\235\214\352\263\274 \353\240\210\353\252\254\354\235\204 \352\263\201\353\223\244\354\227\254 \354\230\250\353\215\224\353\235\275\354\234\274\353\241\234 \353\247\210\354\213\234\352\270\260 \354\242\213\354\235\214.\",\n            flavors = FlavorProfile(sweet = 2, bitter = 1, sour = 1, body = 3, smoky = 0)\n        )\n    )\n}`\n  },\n  {\n    name: \"MainActivity.kt\",\n    path: \"app/src/main/java/com/example/tastingjournal/MainActivity.kt\",\n    language: \"kotlin\",\n    description: \"\354\225\261\354\235\230 \353\251\224\354\235\270 \354\247\204\354\236\205\354\240\220. \353\204\244\353\271\204\352\262\214\354\235\264\354\205\230 \354\273\250\355\212\270\353\241\244\353\237\254(Jetpack Navigation)\354\231\200 Material 3 \355\205\214\353\247\210 \354\204\244\354\240\225\",\n    code: `package com.example.tastingjournal\n\nimport android.os.Bundle\nimport androidx.activity.ComponentActivity\nimport androidx.activity.compose.setContent\nimport androidx.compose.foundation.layout.fillMaxSize\nimport androidx.compose.material3.MaterialTheme\nimport androidx.compose.material3.Surface\nimport androidx.compose.runtime.Composable\nimport androidx.compose.runtime.mutableStateListOf\nimport androidx.compose.runtime.remember\nimport androidx.compose.ui.Modifier\nimport androidx.navigation.NavType\nimport androidx.navigation.compose.NavHost\nimport androidx.navigation.compose.composable\nimport androidx.navigation.compose.rememberNavController\nimport androidx.navigation.navArgument\nimport com.example.tastingjournal.data.DummyData\nimport com.example.tastingjournal.data.TastingEntry\nimport com.example.tastingjournal.ui.screens.TastingDetailScreen\nimport com.example.tastingjournal.ui.screens.TastingFormScreen\nimport com.example.tastingjournal.ui.screens.TastingListScreen\nimport com.example.tastingjournal.ui.theme.TastingJournalTheme\n\nsealed class Screen(val route: String) {\n    object Home : Screen(\"home\")\n    object Add : Screen(\"add\")\n    object Detail : Screen(\"detail/{id}\") {\n        fun createRoute(id: String) = \"detail/$id\"\n    }\n}\n\nclass MainActivity : ComponentActivity() {\n    override class onCreate(savedInstanceState: Bundle?) {\n        super.onCreate(savedInstanceState)\n        setContent {\n            TastingJournalTheme {\n                Surface(\n                    modifier = Modifier.fillMaxSize(),\n                    color = MaterialTheme.colorScheme.background\n                ) {\n                    TastingAppNavigation()\n                }\n            }\n        }\n    }\n}\n\n@Composable\nfun TastingAppNavigation() {\n    val navController = rememberNavController()\n    // \354\203\201\355\203\234 \352\264\200\353\246\254\353\245\274 \354\234\204\355\225\264 \353\251\224\354\235\270 \354\225\241\355\213\260\353\271\204\355\213\260 \354\210\230\354\244\200\354\227\220\354\204\234 \354\203\201\355\203\234 \353\263\264\354\241\264 (\354\213\244\354\240\234 \354\203\201\354\232\251 \354\225\261\354\227\220\354\204\234\353\212\224 ViewModel \354\202\254\354\232\251 \352\266\214\354\236\245)\n    val tastingList = remember { \n        mutableStateListOf<TastingEntry>().apply { \n            addAll(DummyData.sampleTastings) \n        } \n    }\n\n    NavHost(\n        navController = navController,\n        startDestination = Screen.Home.route\n    ) {\n        // 1. \355\231\210 \355\231\224\353\251\264 (\355\205\214\354\235\264\354\212\244\355\214\205 \353\246\254\354\212\244\355\212\270)\n        composable(Screen.Home.route) {\n            TastingListScreen(\n                entries = tastingList,\n                onAddClick = { navController.navigate(Screen.Add.route) },\n                onEntryClick = { entryId -> \n                    navController.navigate(Screen.Detail.createRoute(entryId)) \n                }\n            )\n        }\n\n        // 2. \352\270\260\353\241\235 \354\236\221\354\204\261 \355\231\224\353\251\264 (\355\217\274)\n        composable(Screen.Add.route) {\n            TastingFormScreen(\n                onBackClick = { navController.popBackStack() },\n                onSaveClick = { newEntry ->\n                    tastingList.add(newEntry)\n                    navController.popBackStack()\n                }\n            )\n        }\n\n        // 3. \354\203\201\354\204\270\354\241\260\355\232\214 \355\231\224\353\251\264\n        composable(\n            route = Screen.Detail.route,\n            arguments = listOf(navArgument(\"id\") { type = NavType.StringType })\n        ) { backStackEntry ->\n            val id = backStackEntry.arguments?.getString(\"id\")\n            val entry = tastingList.find { it.id == id }\n\n            if (entry != null) {\n                TastingDetailScreen(\n                    entry = entry,\n                    onBackClick = { navController.popBackStack() },\n                    onDeleteClick = {\n                        tastingList.remove(entry)\n                        navController.popBackStack()\n                    }\n                )\n            }\n        }\n    }\n}`\n  },\n  {\n    name: \"TastingListScreen.kt\",\n    path: \"app/src/main/java/com/example/tastingjournal/ui/screens/TastingListScreen.kt\",\n    language: \"kotlin\",\n    description: \"\355\231\210 \353\246\254\354\212\244\355\212\270 \355\231\224\353\251\264. \355\225\204\355\204\260 \355\203\255, \352\262\200\354\203\211 \353\260\224, \352\267\270\353\246\254\352\263\240 \354\212\244\355\201\254\353\241\244 \352\260\200\353\212\245\355\225\234 \355\205\214\354\235\264\354\212\244\355\214\205 \353\252\251\353\241\235(LazyColumn) \354\240\234\352\263\265\",\n    code: `package com.example.tastingjournal.ui.screens\n\nimport androidx.compose.foundation.background\nimport androidx.compose.foundation.clickable\nimport androidx.compose.foundation.layout.*\nimport androidx.compose.foundation.lazy.LazyColumn\nimport androidx.compose.foundation.lazy.LazyRow\nimport androidx.compose.foundation.lazy.items\nimport androidx.compose.foundation.shape.CircleShape\nimport androidx.compose.foundation.shape.RoundedCornerShape\nimport androidx.compose.material.icons.Icons\nimport androidx.compose.material.icons.filled.Add\nimport androidx.compose.material.icons.filled.Search\nimport androidx.compose.material3.*\nimport androidx.compose.runtime.*\nimport androidx.compose.ui.Alignment\nimport androidx.compose.ui.Modifier\nimport androidx.compose.ui.draw.clip\nimport androidx.compose.ui.graphics.Color\nimport androidx.compose.ui.text.font.FontWeight\nimport androidx.compose.ui.text.style.TextOverflow\nimport androidx.compose.ui.unit.dp\nimport androidx.compose.ui.unit.sp\nimport com.example.tastingjournal.data.LiquorCategory\nimport com.example.tastingjournal.data.TastingEntry\n\n@OptIn(ExperimentalMaterial3Api::class)\n@Composable\nfun TastingListScreen(\n    entries: List<TastingEntry>,\n    onAddClick: () -> Unit,\n    onEntryClick: (String) -> Unit\n) {\n    var searchQuery by remember { mutableStateOf(\"\") }\n    var selectedCategory by remember { mutableStateOf<LiquorCategory?>(null) }\n\n    // \355\225\204\355\204\260\353\247\201 \354\240\201\354\232\251\353\220\234 \353\252\251\353\241\235\n    val filteredEntries = remember(entries, searchQuery, selectedCategory) {\n        entries.filter { entry ->\n            val matchesSearch = entry.name.contains(searchQuery, ignoreCase = true) || \n                                entry.notes.contains(searchQuery, ignoreCase = true)\n            val matchesCategory = selectedCategory == null || entry.category == selectedCategory\n            matchesSearch && matchesCategory\n        }\n    }\n\n    Scaffold(\n        topBar = {\n            TopAppBar(\n                title = { \n                    Text(\n                        \"\353\202\230\354\235\230 \354\243\274\353\245\230 \355\205\214\354\235\264\354\212\244\355\214\205 \354\240\200\353\204\220\", \n                        fontWeight = FontWeight.Bold,\n                        color = MaterialTheme.colorScheme.onSurfaceVariant\n                    ) \n                },\n                colors = TopAppBarDefaults.topAppBarColors(\n                    containerColor = MaterialTheme.colorScheme.surfaceVariant\n                )\n            )\n        },\n        floatingActionButton = {\n            FloatingActionButton(\n                onClick = onAddClick,\n                containerColor = MaterialTheme.colorScheme.primary,\n                contentColor = MaterialTheme.colorScheme.onPrimary,\n                shape = CircleShape\n            ) {\n                Icon(Icons.Default.Add, contentDescription = \"\352\270\260\353\241\235 \354\266\224\352\260\200\")\n            }\n        }\n    ) { paddingValues ->\n        Column(\n            modifier = Modifier\n                .fillMaxSize()\n                .padding(paddingValues)\n                .background(MaterialTheme.colorScheme.background)\n        ) {\n            // 1. \352\262\200\354\203\211\354\260\275\n            OutlinedTextField(\n                value = searchQuery,\n                onValueChange = { searchQuery = it },\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .padding(16.dp),\n                placeholder = { Text(\"\354\210\240 \354\235\264\353\246\204, \353\205\270\355\212\270 \353\202\264\354\232\251 \352\262\200\354\203\211...\") },\n                leadingIcon = { Icon(Icons.Default.Search, contentDescription = \"\352\262\200\354\203\211\") },\n                singleLine = true,\n                shape = RoundedCornerShape(12.dp)\n            )\n\n            // 2. \354\271\264\355\205\214\352\263\240\353\246\254 \355\225\204\355\204\260 \355\203\255\n            LazyRow(\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .padding(horizontal = 16.dp, vertical = 4.dp),\n                horizontalArrangement = Arrangement.spacedBy(8.dp)\n            ) {\n                item {\n                    FilterChip(\n                        selected = selectedCategory == null,\n                        onClick = { selectedCategory = null },\n                        label = { Text(\"\354\240\204\354\262\264\") }\n                    )\n                }\n                items(LiquorCategory.values()) { category ->\n                    FilterChip(\n                        selected = selectedCategory == category,\n                        onClick = { selectedCategory = category },\n                        label = { Text(\"\\${category.icon} \\${category.displayName}\") }\n                    )\n                }\n            }\n\n            Spacer(modifier = Modifier.height(12.dp))\n\n            // 3. \354\243\274\353\245\230 \355\205\214\354\235\264\354\212\244\355\214\205 \353\246\254\354\212\244\355\212\270\n            if (filteredEntries.isEmpty()) {\n                Box(\n                    modifier = Modifier\n                        .weight(1f)\n                        .fillMaxWidth(),\n                    contentAlignment = Alignment.Center\n                ) {\n                    Text(\n                        \"\353\223\261\353\241\235\353\220\234 \355\205\214\354\235\264\354\212\244\355\214\205 \353\205\270\355\212\270\352\260\200 \354\227\206\354\212\265\353\213\210\353\213\244.\",\n                        color = MaterialTheme.colorScheme.onBackground.copy(alpha = 0.6f),\n                        fontSize = 15.sp\n                    )\n                }\n            } else {\n                LazyColumn(\n                    modifier = Modifier\n                        .weight(1f)\n                        .fillMaxWidth(),\n                    contentPadding = PaddingValues(bottom = 80.dp),\n                    verticalArrangement = Arrangement.spacedBy(12.dp)\n                ) {\n                    items(filteredEntries) { entry ->\n                        TastingItemCard(\n                            entry = entry,\n                            onClick = { onEntryClick(entry.id) }\n                        )\n                    }\n                }\n            }\n        }\n    }\n}\n\n@Composable\nfun TastingItemCard(\n    entry: TastingEntry,\n    onClick: () -> Unit\n) {\n    Card(\n        modifier = Modifier\n            .fillMaxWidth()\n            .padding(horizontal = 16.dp)\n            .clickable { onClick() },\n        elevation = CardDefaults.cardElevation(defaultElevation = 2.dp),\n        colors = CardDefaults.cardColors(\n            containerColor = MaterialTheme.colorScheme.surface\n        ),\n        shape = RoundedCornerShape(16.dp)\n    ) {\n        Row(\n            modifier = Modifier\n                .fillMaxWidth()\n                .padding(16.dp),\n            verticalAlignment = Alignment.CenterVertically\n        ) {\n            // \354\235\264\353\252\250\354\247\200 & \353\260\260\352\262\275 \354\233\220\355\230\225 \353\215\260\354\275\224\n            Box(\n                modifier = Modifier\n                    .size(52.dp)\n                    .clip(RoundedCornerShape(12.dp))\n                    .background(MaterialTheme.colorScheme.secondaryContainer),\n                contentAlignment = Alignment.Center\n            ) {\n                Text(entry.category.icon, fontSize = 26.sp)\n            }\n\n            Spacer(modifier = Modifier.width(16.dp))\n\n            Column(\n                modifier = Modifier.weight(1f)\n            ) {\n                Row(\n                    verticalAlignment = Alignment.CenterVertically,\n                    horizontalArrangement = Arrangement.SpaceBetween,\n                    modifier = Modifier.fillMaxWidth()\n                ) {\n                    Text(\n                        text = entry.name,\n                        fontSize = 17.sp,\n                        fontWeight = FontWeight.Bold,\n                        color = MaterialTheme.colorScheme.onSurface,\n                        maxLines = 1,\n                        overflow = TextOverflow.Ellipsis,\n                        modifier = Modifier.weight(1f)\n                    )\n                    \n                    Text(\n                        text = \"\\${entry.abv}%\",\n                        fontSize = 12.sp,\n                        fontWeight = FontWeight.SemiBold,\n                        color = MaterialTheme.colorScheme.primary,\n                        modifier = Modifier.padding(left = 8.dp)\n                    )\n                }\n\n                Spacer(modifier = Modifier.height(4.dp))\n\n                Row(\n                    verticalAlignment = Alignment.CenterVertically\n                ) {\n                    Text(\n                        text = entry.category.displayName,\n                        fontSize = 12.sp,\n                        color = MaterialTheme.colorScheme.onSurfaceVariant\n                    )\n                    Spacer(modifier = Modifier.width(8.dp))\n                    Text(\n                        text = \"\342\200\242  \\${entry.date}\",\n                        fontSize = 12.sp,\n                        color = MaterialTheme.colorScheme.onSurfaceVariant.copy(alpha = 0.7f)\n                    )\n                }\n\n                Spacer(modifier = Modifier.height(6.dp))\n\n                // \353\263\204\354\240\220 \355\221\234\354\213\234\n                Row {\n                    repeat(5) { index ->\n                        val isFilled = index < entry.rating\n                        Text(\n                            text = if (isFilled) \"\342\230\205\" else \"\342\230\206\",\n                            color = if (isFilled) Color(0xFFFFB300) else Color.LightGray,\n                            fontSize = 14.sp\n                        )\n                    }\n                }\n            }\n        }\n    }\n}`\n  },\n  {\n    name: \"TastingFormScreen.kt\",\n    path: \"app/src/main/java/com/example/tastingjournal/ui/screens/TastingFormScreen.kt\",\n    language: \"kotlin\",\n    description: \"\354\243\274\353\245\230 \354\240\225\353\263\264\354\231\200 \354\230\244\352\260\201\355\230\225 \355\226\245\353\257\270(\353\247\233) \355\224\204\353\241\234\355\225\204 \354\212\254\353\235\274\354\235\264\353\215\224, \353\263\204\354\240\220 \354\241\260\354\240\210\354\235\264 \352\260\200\353\212\245\355\225\234 \354\213\240\352\267\234 \355\205\214\354\235\264\354\212\244\355\214\205 \354\236\221\354\204\261 \355\231\224\353\251\264\",\n    code: `package com.example.tastingjournal.ui.screens\n\nimport androidx.compose.foundation.background\nimport androidx.compose.foundation.clickable\nimport androidx.compose.foundation.layout.*\nimport androidx.compose.foundation.rememberScrollState\nimport androidx.compose.foundation.shape.RoundedCornerShape\nimport androidx.compose.foundation.text.KeyboardOptions\nimport androidx.compose.foundation.verticalScroll\nimport androidx.compose.material.icons.Icons\nimport androidx.compose.material.icons.filled.ArrowBack\nimport androidx.compose.material.icons.filled.Check\nimport androidx.compose.material3.*\nimport androidx.compose.runtime.*\nimport androidx.compose.ui.Alignment\nimport androidx.compose.ui.Modifier\nimport androidx.compose.ui.graphics.Color\nimport androidx.compose.ui.text.font.FontWeight\nimport androidx.compose.ui.text.input.KeyboardType\nimport androidx.compose.ui.unit.dp\nimport androidx.compose.ui.unit.sp\nimport com.example.tastingjournal.data.FlavorProfile\nimport com.example.tastingjournal.data.LiquorCategory\nimport com.example.tastingjournal.data.TastingEntry\nimport java.text.SimpleDateFormat\nimport java.util.*\n\n@OptIn(ExperimentalMaterial3Api::class)\n@Composable\nfun TastingFormScreen(\n    onBackClick: () -> Unit,\n    onSaveClick: (TastingEntry) -> Unit\n) {\n    var name by remember { mutableStateOf(\"\") }\n    var selectedCategory by remember { mutableStateOf(LiquorCategory.WHISKEY) }\n    var abvText by remember { mutableStateOf(\"\") }\n    var rating by remember { mutableStateOf(3) }\n    var notes by remember { mutableStateOf(\"\") }\n\n    // \355\226\245\353\257\270 \354\240\220\354\210\230 \354\203\201\355\203\234\n    var sweet by remember { mutableStateOf(2f) }\n    var bitter by remember { mutableStateOf(2f) }\n    var sour by remember { mutableStateOf(2f) }\n    var body by remember { mutableStateOf(2f) }\n    var smoky by remember { mutableStateOf(2f) }\n\n    val scrollState = rememberScrollState()\n\n    Scaffold(\n        topBar = {\n            TopAppBar(\n                title = { Text(\"\354\203\210\353\241\234\354\232\264 \355\205\214\354\235\264\354\212\244\355\214\205 \354\236\221\354\204\261\", fontWeight = FontWeight.Bold) },\n                navigationIcon = {\n                    IconButton(onClick = onBackClick) {\n                        Icon(Icons.Default.ArrowBack, contentDescription = \"\353\222\244\353\241\234\352\260\200\352\270\260\")\n                    }\n                },\n                actions = {\n                    IconButton(\n                        onClick = {\n                            if (name.isNotBlank()) {\n                                val abvValue = abvText.toFloatOrNull() ?: 0f\n                                val todayDate = SimpleDateFormat(\"yyyy-MM-dd\", Locale.getDefault()).format(Date())\n                                \n                                val newEntry = TastingEntry(\n                                    name = name,\n                                    category = selectedCategory,\n                                    abv = abvValue,\n                                    rating = rating,\n                                    date = todayDate,\n                                    notes = notes,\n                                    flavors = FlavorProfile(\n                                        sweet = sweet.toInt(),\n                                        bitter = bitter.toInt(),\n                                        sour = sour.toInt(),\n                                        body = body.toInt(),\n                                        smoky = smoky.toInt()\n                                    )\n                                )\n                                onSaveClick(newEntry)\n                            }\n                        },\n                        enabled = name.isNotBlank()\n                    ) {\n                        Icon(\n                            Icons.Default.Check, \n                            contentDescription = \"\354\240\200\354\236\245\",\n                            tint = if (name.isNotBlank()) MaterialTheme.colorScheme.primary else Color.Gray\n                        )\n                    }\n                }\n            )\n        }\n    ) { paddingValues ->\n        Column(\n            modifier = Modifier\n                .fillMaxSize()\n                .padding(paddingValues)\n                .background(MaterialTheme.colorScheme.background)\n                .verticalScroll(scrollState)\n                .padding(16.dp),\n            verticalArrangement = Arrangement.spacedBy(20.dp)\n        ) {\n            // 1. \354\210\240 \354\235\264\353\246\204 \354\236\205\353\240\245\n            OutlinedTextField(\n                value = name,\n                onValueChange = { name = it },\n                label = { Text(\"\354\210\240 \354\235\264\353\246\204 (\355\225\204\354\210\230)\") },\n                placeholder = { Text(\"\354\230\210: \352\270\200\353\240\214\355\224\274\353\224\225 15\353\205\204, \353\271\214\353\235\274\354\227\240 \353\223\261\") },\n                modifier = Modifier.fillMaxWidth(),\n                singleLine = true,\n                shape = RoundedCornerShape(12.dp)\n            )\n\n            // 2. \354\271\264\355\205\214\352\263\240\353\246\254 \354\204\240\355\203\235\n            Column {\n                Text(\n                    \"\354\243\274\353\245\230 \354\271\264\355\205\214\352\263\240\353\246\254\", \n                    fontSize = 14.sp, \n                    fontWeight = FontWeight.Bold,\n                    color = MaterialTheme.colorScheme.onBackground.copy(alpha = 0.8f)\n                )\n                Spacer(modifier = Modifier.height(8.dp))\n                \n                FlowRow(\n                    modifier = Modifier.fillMaxWidth(),\n                    horizontalArrangement = Arrangement.spacedBy(8.dp),\n                    verticalArrangement = Arrangement.spacedBy(8.dp)\n                ) {\n                    LiquorCategory.values().forEach { category ->\n                        val isSelected = selectedCategory == category\n                        FilterChip(\n                            selected = isSelected,\n                            onClick = { selectedCategory = category },\n                            label = { Text(\"\\${category.icon} \\${category.displayName}\") },\n                            colors = FilterChipDefaults.filterChipColors(\n                                selectedContainerColor = MaterialTheme.colorScheme.primaryContainer,\n                                selectedLabelColor = MaterialTheme.colorScheme.onPrimaryContainer\n                            )\n                        )\n                    }\n                }\n            }\n\n            // 3. \353\217\204\354\210\230 (ABV) \354\236\205\353\240\245\n            OutlinedTextField(\n                value = abvText,\n                onValueChange = { abvText = it },\n                label = { Text(\"\354\225\214\354\275\224\354\230\254 \353\217\204\354\210\230 (%)\") },\n                placeholder = { Text(\"\354\230\210: 40, 13.5\") },\n                keyboardOptions = KeyboardOptions(keyboardType = KeyboardType.Decimal),\n                modifier = Modifier.fillMaxWidth(0.5f),\n                singleLine = true,\n                shape = RoundedCornerShape(12.dp)\n            )\n\n            // 4. \353\263\204\354\240\220 \355\217\211\352\260\200\n            Column {\n                Text(\n                    \"\353\247\214\354\241\261\353\217\204 \353\263\204\354\240\220\", \n                    fontSize = 14.sp, \n                    fontWeight = FontWeight.Bold,\n                    color = MaterialTheme.colorScheme.onBackground.copy(alpha = 0.8f)\n                )\n                Spacer(modifier = Modifier.height(6.dp))\n                Row(\n                    horizontalArrangement = Arrangement.spacedBy(8.dp)\n                ) {\n                    repeat(5) { index ->\n                        val starRating = index + 1\n                        val isSelected = starRating <= rating\n                        Text(\n                            text = if (isSelected) \"\342\230\205\" else \"\342\230\206\",\n                            color = if (isSelected) Color(0xFFFFB300) else Color.LightGray,\n                            fontSize = 32.sp,\n                            modifier = Modifier.clickable { rating = starRating }\n                        )\n                    }\n                }\n            }\n\n            Divider(color = MaterialTheme.colorScheme.outlineVariant)\n\n            // 5. \354\230\244\352\260\201\355\230\225 \354\204\270\353\266\200 \353\247\233 \355\217\211\352\260\200 \354\212\254\353\235\274\354\235\264\353\215\224\n            Column {\n                Text(\n                    \"\353\247\233 & \355\226\245\353\257\270 \355\224\204\353\241\234\355\225\204 (0-5\354\240\220)\", \n                    fontSize = 16.sp, \n                    fontWeight = FontWeight.Bold,\n                    color = MaterialTheme.colorScheme.primary\n                )\n                Spacer(modifier = Modifier.height(16.dp))\n\n                FlavorSliderItem(\"\353\213\250\353\247\233 (Sweet)\", sweet) { sweet = it }\n                FlavorSliderItem(\"\354\223\264\353\247\233 (Bitter)\", bitter) { bitter = it }\n                FlavorSliderItem(\"\354\213\240\353\247\233 (Sour)\", sour) { sour = it }\n                FlavorSliderItem(\"\353\260\224\353\224\224\352\260\220 (Body)\", body) { body = it }\n                FlavorSliderItem(\"\354\212\244\353\252\250\355\202\244\355\225\250 (Smoky)\", smoky) { smoky = it }\n            }\n\n            Divider(color = MaterialTheme.colorScheme.outlineVariant)\n\n            // 6. \354\213\234\354\235\214 \353\205\270\355\212\270 \354\203\201\354\204\270 \353\251\224\353\252\250 \354\236\221\354\204\261\n            OutlinedTextField(\n                value = notes,\n                onValueChange = { notes = it },\n                label = { Text(\"\354\203\201\354\204\270 \354\213\234\354\235\214 \355\217\211 \353\260\217 \353\251\224\353\252\250\") },\n                placeholder = { Text(\"\355\226\245, \353\247\233, \353\252\251\353\204\230\352\271\200, \354\226\264\354\232\270\353\246\254\353\212\224 \354\225\210\354\243\274 \353\223\261\354\235\204 \354\236\220\354\234\240\353\241\255\352\262\214 \352\270\260\353\241\235\355\225\264 \353\263\264\354\204\270\354\232\224.\") },\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .height(150.dp),\n                maxLines = 6,\n                shape = RoundedCornerShape(12.dp)\n            )\n\n            // 7. \355\225\230\353\213\250 \352\260\200\354\235\264\353\223\234 \353\260\217 \354\240\200\354\236\245 \353\262\204\355\212\274\n            Button(\n                onClick = {\n                    if (name.isNotBlank()) {\n                        val abvValue = abvText.toFloatOrNull() ?: 0f\n                        val todayDate = SimpleDateFormat(\"yyyy-MM-dd\", Locale.getDefault()).format(Date())\n                        \n                        val newEntry = TastingEntry(\n                            name = name,\n                            category = selectedCategory,\n                            abv = abvValue,\n                            rating = rating,\n                            date = todayDate,\n                            notes = notes,\n                            flavors = FlavorProfile(\n                                sweet = sweet.toInt(),\n                                bitter = bitter.toInt(),\n                                sour = sour.toInt(),\n                                body = body.toInt(),\n                                smoky = smoky.toInt()\n                            )\n                        )\n                        onSaveClick(newEntry)\n                    }\n                },\n                modifier = Modifier\n                    .fillMaxWidth()\n                    .height(52.dp),\n                enabled = name.isNotBlank(),\n                shape = RoundedCornerShape(12.dp)\n            ) {\n                Text(\"\352\270\260\353\241\235 \354\231\204\353\243\214\", fontSize = 16.sp, fontWeight = FontWeight.Bold)\n            }\n        }\n    }\n}\n\n@Composable\nfun FlavorSliderItem(\n    label: String,\n    value: Float,\n    onValueChange: (Float) -> Unit\n) {\n    Row(\n        modifier = Modifier\n            .fillMaxWidth()\n            .padding(vertical = 4.dp),\n        verticalAlignment = Alignment.CenterVertically\n    ) {\n        Text(\n            text = label, \n            modifier = Modifier.width(110.dp), \n            fontSize = 14.sp,\n            fontWeight = FontWeight.Medium\n        )\n        \n        Slider(\n            value = value,\n            onValueChange = onValueChange,\n            valueRange = 0f..5f,\n            steps = 4,\n            modifier = Modifier.weight(1f)\n        )\n        \n        Spacer(modifier = Modifier.width(12.dp))\n        \n        Text(\n            text = \"\\${value.toInt()}\354\240\220\", \n            fontWeight = FontWeight.Bold, \n            color = MaterialTheme.colorScheme.primary,\n            fontSize = 14.sp,\n            modifier = Modifier.width(32.dp)\n        )\n    }\n}\n`\n  },\n  {\n    name: \"TastingDetailScreen.kt\",\n    path: \"app/src/main/java/com/example/tastingjournal/ui/screens/TastingDetailScreen.kt\",\n    language: \"kotlin\",\n    description: \"\354\204\240\355\203\235\355\225\234 \354\243\274\353\245\230\354\235\230 \354\203\201\354\204\270 \352\270\260\353\241\235 \355\231\224\353\251\264. \354\230\210\354\201\234 \355\226\245\353\257\270 \355\224\204\353\241\234\355\225\204 \353\247\211\353\214\200 \354\260\250\355\212\270\354\231\200 \352\260\220\353\217\204 \352\271\212\354\235\200 \354\203\201\354\204\270 \354\213\234\354\235\214\355\217\211 \355\221\234\355\230\204\",\n    code: `package com.example.tastingjournal.ui.screens\n\nimport androidx.compose.foundation.background\nimport androidx.compose.foundation.layout.*\nimport androidx.compose.foundation.rememberScrollState\nimport androidx.compose.foundation.shape.RoundedCornerShape\nimport androidx.compose.foundation.verticalScroll\nimport androidx.compose.material.icons.Icons\nimport androidx.compose.material.icons.filled.ArrowBack\nimport androidx.compose.material.icons.filled.Delete\nimport androidx.compose.material3.*\nimport androidx.compose.runtime.*\nimport androidx.compose.ui.Alignment\nimport androidx.compose.ui.Modifier\nimport androidx.compose.ui.graphics.Color\nimport androidx.compose.ui.text.font.FontWeight\nimport androidx.compose.ui.unit.dp\nimport androidx.compose.ui.unit.sp\nimport com.example.tastingjournal.data.TastingEntry\n\n@OptIn(ExperimentalMaterial3Api::class)\n@Composable\nfun TastingDetailScreen(\n    entry: TastingEntry,\n    onBackClick: () -> Unit,\n    onDeleteClick: () -> Unit\n) {\n    var showDeleteDialog by remember { mutableStateOf(false) }\n    val scrollState = rememberScrollState()\n\n    if (showDeleteDialog) {\n        AlertDialog(\n            onDismissRequest = { showDeleteDialog = false },\n            title = { Text(\"\352\270\260\353\241\235 \354\202\255\354\240\234\") },\n            text = { Text(\"\354\235\264 \355\205\214\354\235\264\354\212\244\355\214\205 \353\205\270\355\212\270\353\245\274 \354\240\225\353\247\220 \354\202\255\354\240\234\355\225\230\354\213\234\352\262\240\354\212\265\353\213\210\352\271\214?\") },\n            confirmButton = {\n                TextButton(\n                    onClick = {\n                        showDeleteDialog = false\n                        onDeleteClick()\n                    }\n                ) {\n                    Text(\"\354\202\255\354\240\234\", color = MaterialTheme.colorScheme.error)\n                }\n            },\n            dismissButton = {\n                TextButton(onClick = { showDeleteDialog = false }) {\n                    Text(\"\354\267\250\354\206\214\")\n                }\n            }\n        )\n    }\n\n    Scaffold(\n        topBar = {\n            TopAppBar(\n                title = { Text(\"\354\213\234\354\235\214 \354\203\201\354\204\270 \353\246\254\353\267\260\", fontWeight = FontWeight.Bold) },\n                navigationIcon = {\n                    IconButton(onClick = onBackClick) {\n                        Icon(Icons.Default.ArrowBack, contentDescription = \"\353\222\244\353\241\234\352\260\200\352\270\260\")\n                    }\n                },\n                actions = {\n                    IconButton(onClick = { showDeleteDialog = true }) {\n                        Icon(\n                            Icons.Default.Delete, \n                            contentDescription = \"\354\202\255\354\240\234\",\n                            tint = MaterialTheme.colorScheme.error\n                        )\n                    }\n                }\n            )\n        }\n    ) { paddingValues ->\n        Column(\n            modifier = Modifier\n                .fillMaxSize()\n                .padding(paddingValues)\n                .background(MaterialTheme.colorScheme.background)\n                .verticalScroll(scrollState)\n                .padding(16.dp),\n            verticalArrangement = Arrangement.spacedBy(20.dp)\n        ) {\n            // 1. \355\227\244\353\215\224 \354\271\264\353\223\234 (\354\210\240 \354\240\225\353\263\264 \354\232\224\354\225\275)\n            Card(\n                modifier = Modifier.fillMaxWidth(),\n                colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.primaryContainer),\n                shape = RoundedCornerShape(20.dp)\n            ) {\n                Column(\n                    modifier = Modifier.padding(20.dp),\n                    horizontalAlignment = Alignment.CenterHorizontally\n                ) {\n                    Text(entry.category.icon, fontSize = 48.sp)\n                    Spacer(modifier = Modifier.height(12.dp))\n                    Text(\n                        text = entry.name,\n                        fontSize = 22.sp,\n                        fontWeight = FontWeight.Bold,\n                        color = MaterialTheme.colorScheme.onPrimaryContainer\n                    )\n                    Spacer(modifier = Modifier.height(4.dp))\n                    Row(\n                        horizontalArrangement = Arrangement.spacedBy(8.dp),\n                        verticalAlignment = Alignment.CenterVertically\n                    ) {\n                        SuggestionChip(\n                            onClick = {},\n                            label = { Text(entry.category.displayName) }\n                        )\n                        SuggestionChip(\n                            onClick = {},\n                            label = { Text(\"ABV \\${entry.abv}%\") }\n                        )\n                    }\n\n                    Spacer(modifier = Modifier.height(12.dp))\n\n                    // \353\263\204\354\240\220 \355\217\211\354\240\220\n                    Row {\n                        repeat(5) { index ->\n                            val isFilled = index < entry.rating\n                            Text(\n                                text = if (isFilled) \"\342\230\205\" else \"\342\230\206\",\n                                color = if (isFilled) Color(0xFFFFB300) else Color.LightGray.copy(alpha = 0.5f),\n                                fontSize = 24.sp\n                            )\n                        }\n                    }\n                    Spacer(modifier = Modifier.height(4.dp))\n                    Text(\n                        text = \"\352\270\260\353\241\235\354\235\274: \\${entry.date}\",\n                        fontSize = 12.sp,\n                        color = MaterialTheme.colorScheme.onPrimaryContainer.copy(alpha = 0.7f)\n                    )\n                }\n            }\n\n            // 2. \354\230\244\352\260\201\355\230\225 \355\226\245\353\257\270(\353\247\233) \354\203\201\354\204\270 \353\271\204\354\243\274\354\226\274 \354\260\250\355\212\270\n            Card(\n                modifier = Modifier.fillMaxWidth(),\n                shape = RoundedCornerShape(16.dp),\n                colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface)\n            ) {\n                Column(\n                    modifier = Modifier.padding(16.dp)\n                ) {\n                    Text(\n                        text = \"\355\226\245\353\257\270 \353\247\233 \354\212\244\355\216\231\355\212\270\353\237\274\",\n                        fontSize = 15.sp,\n                        fontWeight = FontWeight.Bold,\n                        color = MaterialTheme.colorScheme.primary,\n                        modifier = Modifier.padding(bottom = 16.dp)\n                    )\n\n                    DetailFlavorBar(\"\353\213\250\353\247\233 (Sweet)\", entry.flavors.sweet)\n                    DetailFlavorBar(\"\354\223\264\353\247\233 (Bitter)\", entry.flavors.bitter)\n                    DetailFlavorBar(\"\354\213\240\353\247\233 (Sour)\", entry.flavors.sour)\n                    DetailFlavorBar(\"\353\260\224\353\224\224\352\260\220 (Body)\", entry.flavors.body)\n                    DetailFlavorBar(\"\354\212\244\353\252\250\355\202\244\355\225\250 (Smoky)\", entry.flavors.smoky)\n                }\n            }\n\n            // 3. \354\203\201\354\204\270 \355\205\214\354\235\264\354\212\244\355\214\205 \353\251\224\353\252\250\n            Card(\n                modifier = Modifier.fillMaxWidth(),\n                shape = RoundedCornerShape(16.dp),\n                colors = CardDefaults.cardColors(containerColor = MaterialTheme.colorScheme.surface)\n            ) {\n                Column(\n                    modifier = Modifier.padding(16.dp)\n                ) {\n                    Text(\n                        text = \"\354\203\201\354\204\270 \354\213\234\354\235\214\355\217\211\",\n                        fontSize = 15.sp,\n                        fontWeight = FontWeight.Bold,\n                        color = MaterialTheme.colorScheme.primary,\n                        modifier = Modifier.padding(bottom = 12.dp)\n                    )\n\n                    Text(\n                        text = if (entry.notes.isNotBlank()) entry.notes else \"\352\270\260\353\241\235\353\220\234 \354\204\270\353\266\200 \355\205\214\354\235\264\354\212\244\355\214\205 \353\251\224\353\252\250\352\260\200 \354\227\206\354\212\265\353\213\210\353\213\244.\",\n                        fontSize = 14.sp,\n                        lineHeight = 22.sp,\n                        color = MaterialTheme.colorScheme.onSurface\n                    )\n                }\n            }\n        }\n    }\n}\n\n@Composable\nfun DetailFlavorBar(\n    label: String,\n    value: Int\n) {\n    Column(\n        modifier = Modifier\n            .fillMaxWidth()\n            .padding(vertical = 6.dp)\n    ) {\n        Row(\n            modifier = Modifier.fillMaxWidth(),\n            horizontalArrangement = Arrangement.SpaceBetween\n        ) {\n            Text(text = label, fontSize = 13.sp, fontWeight = FontWeight.Medium)\n            Text(\n                text = \"\\${value} / 5\", \n                fontSize = 13.sp, \n                fontWeight = FontWeight.Bold, \n                color = MaterialTheme.colorScheme.primary\n            )\n        }\n        Spacer(modifier = Modifier.height(4.dp))\n        \n        // \354\273\244\354\212\244\355\205\200 \355\224\204\353\241\234\352\267\270\353\240\210\354\212\244\353\260\224 \352\265\254\355\230\204 (0-5\354\240\220 \353\210\210\352\270\210 \355\221\234\355\230\204)\n        LinearProgressIndicator(\n            progress = value / 5f,\n            modifier = Modifier\n                .fillMaxWidth()\n                .height(8.dp),\n            color = MaterialTheme.colorScheme.primary,\n            trackColor = MaterialTheme.colorScheme.primaryContainer.copy(alpha = 0.3f),\n            strokeCap = StrokeCap.Round\n        )\n    }\n}\n`\n  },\n  {\n    name: \"Theme.kt\",\n    path: \"app/src/main/java/com/example/tastingjournal/ui/theme/Theme.kt\",\n    language: \"kotlin\",\n    description: \"\355\205\214\354\235\264\354\212\244\355\214\205 \354\240\200\353\204\220\354\227\220 \354\226\264\354\232\270\353\246\254\353\212\224 \352\263\240\352\270\211\354\212\244\353\237\254\354\232\264 \353\202\230\353\254\264/\352\265\254\353\246\254/\355\230\270\353\260\225\354\204\235 \353\212\220\353\202\214\354\235\230 Material 3 \354\203\211\354\203\201 \355\205\214\353\247\210 \354\204\244\354\240\225\",\n    code: `package com.example.tastingjournal.ui.theme\n\nimport android.os.Build\nimport androidx.compose.foundation.isSystemInDarkTheme\nimport androidx.compose.material3.*\nimport androidx.compose.runtime.Composable\nimport androidx.compose.ui.graphics.Color\n\n// \352\263\240\352\270\211\354\212\244\353\237\254\354\232\264 \354\234\204\354\212\244\355\202\244 \352\263\250\353\223\234 \353\260\217 \353\224\245 \354\230\244\355\201\254 \353\270\214\353\235\274\354\232\264 \355\205\214\353\247\210 \353\270\214\353\236\234\353\224\251 \354\273\254\353\237\254\nprivate val DarkColorScheme = darkColorScheme(\n    primary = Color(0xFFE5A93C),          // \354\225\204\353\212\221\355\225\234 \355\227\210\353\213\210 \352\263\250\353\223\234\n    onPrimary = Color(0xFF422C00),\n    primaryContainer = Color(0xFF5E4100),\n    onPrimaryContainer = Color(0xFFFFDEAC),\n    secondary = Color(0xFFD6C3B1),        // \353\260\235\354\235\200 \353\252\250\353\236\230\354\203\211\n    onSecondary = Color(0xFF3A2E24),\n    secondaryContainer = Color(0xFF514439),\n    onSecondaryContainer = Color(0xFFF3DFCE),\n    background = Color(0xFF1C1B18),       // \354\225\204\353\212\221\355\225\234 \354\226\264\353\221\220\354\232\264 \352\260\210\354\203\211 \352\263\204\354\227\264 \353\260\260\352\262\275\n    surface = Color(0xFF252420),\n    onBackground = Color(0xFFE6E2DB),\n    onSurface = Color(0xFFE6E2DB),\n    surfaceVariant = Color(0xFF32302A),\n    onSurfaceVariant = Color(0xFFD0C6B8)\n)\n\nprivate val LightColorScheme = lightColorScheme(\n    primary = Color(0xFF865D00),         // \353\224\245 \354\230\244\355\201\254 \355\227\210\353\213\210\n    onPrimary = Color(0xFFFFFFFF),\n    primaryContainer = Color(0xFFFFDEAC),\n    onPrimaryContainer = Color(0xFF2B1B00),\n    secondary = Color(0xFF6E5D4F),       // \355\206\240\355\224\204 \353\270\214\353\235\274\354\232\264\n    onSecondary = Color(0xFFFFFFFF),\n    secondaryContainer = Color(0xFFF9EDE2),\n    onSecondaryContainer = Color(0xFF271B10),\n    background = Color(0xFFFDFBF7),      // \353\266\200\353\223\234\353\237\254\354\232\264 \354\225\204\354\235\264\353\263\264\353\246\254 \355\206\244 \355\231\224\354\235\264\355\212\270\n    surface = Color(0xFFFFFFFF),\n    onBackground = Color(0xFF1E1B16),\n    onSurface = Color(0xFF1E1B16),\n    surfaceVariant = Color(0xFFF0E5D8),\n    onSurfaceVariant = Color(0xFF4F4539)\n)\n\n@Composable\nfun TastingJournalTheme(\n    darkTheme: Boolean = isSystemInDarkTheme(),\n    dynamicColor: Boolean = false, // \354\273\244\354\212\244\355\205\200 \353\270\214\353\235\274\354\232\264 \354\273\254\353\237\254 \354\225\204\354\235\264\353\215\264\355\213\260\355\213\260 \354\234\240\354\247\200\353\245\274 \354\234\204\355\225\264 \352\270\260\353\263\270 false\n    content: @Composable () -> Unit\n) {\n    val colorScheme = when {\n        dynamicColor && Build.VERSION.SDK_INT >= Build.VERSION_CODES_S -> {\n            // \354\225\210\353\223\234\353\241\234\354\235\264\353\223\234 12+ \353\217\231\354\240\201 \354\273\254\353\237\254 \354\247\200\354\233\220\354\235\264 \355\225\204\354\232\224\355\225\234 \352\262\275\354\232\260 \354\204\244\354\240\225\n            val context = androidx.compose.ui.platform.LocalContext.current\n            if (darkTheme) dynamicDarkColorScheme(context) else dynamicLightColorScheme(context)\n        }\n        darkTheme -> DarkColorScheme\n        else -> LightColorScheme\n    }\n\n    MaterialTheme(\n        colorScheme = colorScheme,\n        typography = Typography(), // \352\270\260\353\263\270\354\240\201\354\235\270 M3 \355\203\200\354\235\264\355\217\254\352\267\270\353\236\230\355\224\274 \355\231\234\354\232\251\n        content = content\n    )\n}\n`\n  }\n];\n"
    }
