        lines {
          text: "\354\232\260\354\270\241 `CodeViewer`\354\227\220 \355\221\234\354\213\234\353\220\230\353\212\224 Kotlin/Compose \354\275\224\353\223\234\353\212\224 \354\225\210\353\223\234\353\241\234\354\235\264\353\223\234 \354\212\244\355\212\234\353\224\224\354\230\244\354\227\220 \353\266\231\354\227\254\353\204\243\354\227\210\354\235\204 \353\225\214 \354\246\211\354\213\234 \354\273\264\355\214\214\354\235\274 \352\260\200\353\212\245\355\225\264\354\225\274 \355\225\251\353\213\210\353\213\244."
