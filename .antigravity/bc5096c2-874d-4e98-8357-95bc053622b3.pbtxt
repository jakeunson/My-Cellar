  file_change {
    absolute_path_uri: "file:///AGENTS.md"
    file_change_type: FILE_CHANGE_TYPE_CREATE
    replacement_chunks {
      replacement_content: "# \360\237\244\226 AI Coding Agent Behavior Rules (\354\227\220\354\235\264\354\240\204\355\212\270 \355\226\211\353\217\231 \352\267\234\354\271\231)\n\n\354\235\264 \355\214\214\354\235\274\354\235\200 **Jetpack Compose \354\243\274\353\245\230 \355\205\214\354\235\264\354\212\244\355\214\205 \354\240\200\353\204\220 (Liquor Tasting Journal)** \355\224\204\353\241\234\354\240\235\355\212\270\353\245\274 \354\234\204\355\225\234 AI \354\275\224\353\224\251 \354\227\220\354\235\264\354\240\204\355\212\270 \354\240\204\354\232\251 \354\247\200\354\271\250 \353\260\217 \355\226\211\353\217\231 \352\267\234\354\271\231 \353\254\270\354\204\234\354\236\205\353\213\210\353\213\244. \354\227\220\354\235\264\354\240\204\355\212\270\353\212\224 \355\226\245\355\233\204 \354\235\264 \355\224\204\353\241\234\354\240\235\355\212\270\354\235\230 \354\275\224\353\223\234\353\245\274 \354\210\230\354\240\225\355\225\230\352\261\260\353\202\230 \352\270\260\353\212\245\354\235\204 \354\266\224\352\260\200\355\225\240 \353\225\214 \354\225\204\353\236\230\354\235\230 \352\267\234\354\271\231\354\235\204 \354\227\204\352\262\251\355\236\210 \354\244\200\354\210\230\355\225\264\354\225\274 \355\225\251\353\213\210\353\213\244.\n\n---\n\n## 1. \355\224\204\353\241\234\354\240\235\355\212\270 \355\225\265\354\213\254 \353\252\251\354\240\201 \353\260\217 \354\240\225\354\262\264\354\204\261 (Identity)\n* **\353\252\251\354\240\201**: \354\235\264 \354\225\261\354\235\200 \354\225\210\353\223\234\353\241\234\354\235\264\353\223\234 **Material Design 3 (M3)** \353\260\217 **Jetpack Compose**\353\245\274 \352\270\260\353\260\230\354\234\274\353\241\234 \354\236\221\353\217\231\355\225\230\353\212\224 \354\243\274\353\245\230 \355\205\214\354\235\264\354\212\244\355\214\205 \354\240\200\353\204\220 \354\225\261\354\235\230 \352\265\254\354\241\260 \354\204\244\352\263\204, \355\231\224\353\251\264 \355\235\220\353\246\204 \354\213\234\353\256\254\353\240\210\354\235\264\354\205\230 \353\260\217 \354\213\244\354\240\234 \353\271\214\353\223\234 \352\260\200\353\212\245\355\225\234 \354\275\224\355\213\200\353\246\260(Kotlin) \354\275\224\353\223\234\353\245\274 \354\240\234\352\263\265\355\225\230\353\212\224 \355\206\265\355\225\251 \353\217\204\352\265\254\354\236\205\353\213\210\353\213\244.\n* **\354\240\225\354\262\264\354\204\261**: \n  * \354\231\274\354\252\275\354\227\220\353\212\224 \354\213\244\354\240\234 \354\236\221\353\217\231\354\235\204 \354\213\234\352\260\201\355\231\224\355\225\230\353\212\224 \353\252\250\353\260\224\354\235\274 \355\230\225\355\203\234\354\235\230 **Phone Simulator (React)**\352\260\200 \355\203\221\354\236\254\353\220\230\354\226\264 \354\236\210\352\263\240, \354\230\244\353\245\270\354\252\275\354\227\220\353\212\224 \354\235\264\354\227\220 \353\217\231\352\270\260\355\231\224\353\220\230\353\212\224 **Code Viewer (Kotlin)**\352\260\200 \353\260\260\354\271\230\353\220\230\354\226\264 \354\236\210\354\212\265\353\213\210\353\213\244.\n  * \354\213\234\353\256\254\353\240\210\354\235\264\355\204\260\354\235\230 \355\231\224\353\251\264 \355\235\220\353\246\204 \353\260\217 \354\203\201\355\203\234 \353\263\200\355\231\224\353\212\224 \354\232\260\354\270\241 \354\275\224\353\223\234 \353\267\260\354\226\264\354\227\220 \355\221\234\354\213\234\353\220\230\353\212\224 \355\214\214\354\235\274\352\263\274 \353\260\200\354\240\221\355\225\230\352\262\214 \354\227\260\353\217\231(Sync)\353\220\230\354\226\264\354\225\274 \355\225\251\353\213\210\353\213\244.\n\n---\n\n## 2. \353\224\224\354\236\220\354\235\270 \353\260\217 \353\240\210\354\235\264\354\225\204\354\233\203 \354\233\220\354\271\231 (Design Principles)\n* **\353\271\204\354\243\274\354\226\274 \355\205\214\353\247\210**: \n  * \354\260\250\353\266\204\355\225\234 **Slate(\355\232\214\354\203\211/\353\202\250\354\203\211 \352\263\204\354\227\264)** \354\272\224\353\262\204\354\212\244\354\231\200 \352\277\200\353\271\233 \354\234\204\354\212\244\355\202\244 \352\263\250\353\223\234 \353\260\217 \354\260\270\353\202\230\353\254\264 \352\260\210\354\203\211\354\235\270 **Amber/Oak** \352\263\204\354\227\264 \354\225\205\354\204\274\355\212\270 \354\273\254\353\237\254\352\260\200 \354\241\260\355\231\224\353\241\255\352\262\214 \353\205\271\354\225\204\353\223\240 \352\263\240\353\214\200\353\271\204 \353\235\274\354\235\264\355\212\270/\353\204\244\354\266\224\353\237\264 \354\212\244\355\203\200\354\235\274\354\235\204 \354\234\240\354\247\200\355\225\251\353\213\210\353\213\244.\n  * \352\262\254\352\263\240\355\225\234 \352\270\260\355\225\230\355\225\231\354\240\201 \355\230\225\355\203\234\354\235\230 \352\265\265\354\235\200 \353\263\264\353\215\224\353\235\274\354\235\270(Slate-900 \354\234\204\354\243\274\354\235\230 \355\205\214\353\221\220\353\246\254, `border-4` \353\223\261)\352\263\274 \352\260\234\354\204\261 \354\236\210\353\212\224 \353\257\270\353\213\210\353\251\200/\353\204\244\354\230\244\353\270\214\353\243\250\355\203\210\353\246\254\354\246\230 \353\224\224\354\236\220\354\235\270 \354\225\204\354\235\264\353\215\264\355\213\260\355\213\260\353\245\274 \353\263\264\354\241\264\355\225\251\353\213\210\353\213\244.\n* **\355\203\200\354\235\264\355\217\254\352\267\270\353\236\230\355\224\274**:\n  * \353\224\224\354\212\244\355\224\214\353\240\210\354\235\264 \353\260\217 \355\227\244\353\215\224 \354\230\201\354\227\255\354\227\220\353\212\224 \352\270\260\355\225\230\355\225\231\354\240\201\354\235\264\352\263\240 \355\230\204\353\214\200\354\240\201\354\235\270 \355\217\260\355\212\270 \352\265\265\352\270\260\353\245\274 \354\202\254\354\232\251\355\225\230\352\263\240, \354\275\224\353\223\234 \354\230\201\354\227\255\354\235\200 \354\235\274\352\264\200\353\220\234 \353\252\250\353\205\270\354\212\244\355\216\230\354\235\264\354\212\244(`font-mono`) \355\217\260\355\212\270\353\245\274 \354\202\254\354\232\251\355\225\251\353\213\210\353\213\244.\n  * \355\225\234\352\265\255\354\226\264 \355\205\215\354\212\244\355\212\270\354\231\200 \352\260\200\353\217\205\354\204\261 \354\236\210\353\212\224 \355\217\260\355\212\270 \354\212\244\354\274\200\354\235\274\353\247\201, \354\266\251\353\266\204\355\225\234 \354\227\254\353\260\261 \353\260\217 \353\214\200\353\271\204(Contrast)\353\245\274 \355\231\225\353\263\264\355\225\230\354\227\254 \355\203\201\354\233\224\355\225\234 \354\213\234\352\260\201\354\240\201 \354\231\204\354\204\261\353\217\204\353\245\274 \354\240\234\352\263\265\355\225\251\353\213\210\353\213\244.\n* **\354\225\204\354\235\264\354\275\230**:\n  * \353\252\250\353\223\240 \353\246\254\354\225\241\355\212\270 UI \354\225\204\354\235\264\354\275\230\354\235\200 `lucide-react`\354\227\220\354\204\234 \354\247\201\354\240\221 \353\252\205\353\252\205\353\220\234 \354\273\264\355\217\254\353\204\214\355\212\270\353\241\234 \354\236\204\355\217\254\355\212\270\355\225\230\354\227\254 \354\202\254\354\232\251\355\225\230\353\251\260, \354\236\204\354\235\230\354\235\230 \354\235\270\353\235\274\354\235\270 SVG \354\202\254\354\232\251\354\235\200 \352\270\210\354\247\200\355\225\251\353\213\210\353\213\244.\n\n---\n\n## 3. Jetpack Compose & \354\225\210\353\223\234\353\241\234\354\235\264\353\223\234 \354\275\224\353\223\234 \354\236\221\354\204\261 \352\267\234\354\271\231\n\354\232\260\354\270\241 `CodeViewer`\354\227\220 \355\221\234\354\213\234\353\220\230\353\212\224 Kotlin/Compose \354\275\224\353\223\234\353\212\224 \354\225\210\353\223\234\353\241\234\354\235\264\353\223\234 \354\212\244\355\212\234\353\224\224\354\230\244\354\227\220 \353\266\231\354\227\254\353\204\243\354\227\210\354\235\204 \353\225\214 \354\246\211\354\213\234 \354\273\264\355\214\214\354\235\274 \352\260\200\353\212\245\355\225\264\354\225\274 \355\225\251\353\213\210\353\213\244.\n* **Material Design 3 (M3) \354\244\200\354\210\230**: `androidx.compose.material3` \355\214\250\355\202\244\354\247\200\354\235\230 \354\265\234\354\213\240 \354\273\264\355\217\254\353\204\214\355\212\270(`Scaffold`, `MediumTopAppBar`, `Button`, `FilterChip`, `Slider`, `Card`)\353\245\274 \354\266\251\354\213\244\355\236\210 \353\224\260\353\246\205\353\213\210\353\213\244.\n* **\354\203\201\355\203\234 \352\264\200\353\246\254 \353\260\217 \353\213\250\353\260\251\355\226\245 \353\215\260\354\235\264\355\204\260 \355\235\220\353\246\204 (UDF)**:\n  * \354\273\264\355\217\254\354\240\200\353\270\224 \353\202\264\354\227\220\354\204\234 \354\247\201\354\240\221 \354\203\201\355\203\234\353\245\274 \354\241\260\354\236\221\355\225\230\354\247\200 \354\225\212\352\263\240, \354\203\201\355\203\234 \355\230\270\354\235\264\354\212\244\355\214\205(State Hoisting) \352\270\260\353\262\225\354\235\204 \354\202\254\354\232\251\355\225\230\354\227\254 \354\203\201\355\203\234(`remember { mutableStateOf(...) }`)\354\231\200 \354\235\264\353\262\244\355\212\270 \354\275\234\353\260\261(`onValueChange`, `onClick`)\354\235\204 \352\271\224\353\201\224\355\236\210 \353\266\204\353\246\254\355\225\251\353\213\210\353\213\244.\n* **\353\204\244\353\271\204\352\262\214\354\235\264\354\205\230 \352\265\254\354\241\260 \354\204\244\352\263\204**:\n  * \353\213\250\354\235\274 \354\225\241\355\213\260\353\271\204\355\213\260 \353\202\264\354\227\220\354\204\234 \354\204\240\354\226\270\355\230\225 \353\204\244\353\271\204\352\262\214\354\235\264\354\205\230(`NavHost`, `composable`, `NavController`) \352\265\254\354\241\260\353\245\274 \352\260\200\354\247\200\353\251\260, \353\235\274\354\232\260\355\212\270 \353\204\244\354\235\264\353\260\215(`\"home\"`, `\"add\"`, `\"detail/{id}\"`) \352\267\234\354\271\231\354\235\204 \353\252\205\355\231\225\355\236\210 \354\240\225\354\235\230\355\225\251\353\213\210\353\213\244.\n\n---\n\n## 4. \352\270\260\353\212\245 \354\266\224\352\260\200 \353\260\217 \354\210\230\354\240\225 \354\213\234 \354\227\220\354\235\264\354\240\204\355\212\270 \352\270\210\354\247\200 \354\202\254\355\225\255 (Strict Negative Constraints)\n* **\354\236\204\354\235\230\354\240\201\354\235\270 \355\205\214\353\247\210 \355\214\214\352\264\264 \352\270\210\354\247\200**: \352\270\260\352\273\217 \352\265\254\354\204\261\355\225\264 \353\221\224 \354\204\270\353\240\250\353\220\234 \352\263\240\353\214\200\353\271\204 Slate & Amber \354\241\260\355\225\251\354\235\230 \355\206\244\354\225\244\353\247\244\353\204\210\353\245\274 \352\271\250\355\212\270\353\246\254\352\261\260\353\202\230 \355\235\224\355\225\234 \353\263\264\353\235\274\354\203\211/\352\267\270\353\235\274\353\215\260\354\235\264\354\205\230 \355\205\234\355\224\214\353\246\277 \355\230\225\355\203\234\353\241\234 \355\232\214\352\267\200\355\225\230\354\247\200 \353\247\210\354\213\255\354\213\234\354\230\244.\n* **\354\213\234\354\212\244\355\205\234 \353\241\234\352\271\205/\352\270\260\352\263\204 \353\215\260\354\235\264\355\204\260 \354\266\224\352\260\200 \354\236\220\354\240\234**: UI \354\227\254\353\260\261\354\235\264\353\202\230 \352\260\200\353\221\220\353\246\254\354\227\220 \353\266\210\355\225\204\354\232\224\355\225\234 \354\213\234\354\212\244\355\205\234 \353\251\224\355\203\200\353\215\260\354\235\264\355\204\260, \353\241\234\352\267\270 \354\266\234\353\240\245, \354\213\234\353\256\254\353\240\210\354\235\264\354\205\230 \355\225\221 \354\203\201\355\203\234(\354\230\210: `\342\227\217 SYSTEM LIVE`, `PORT: 3000`)\353\245\274 \354\247\200\354\240\200\353\266\204\355\225\230\352\262\214 \354\266\224\352\260\200\355\225\264 \354\243\274\353\212\224 \"\352\270\260\354\210\240 \354\213\234\353\212\211(Tech-Larping)\"\354\235\200 \354\262\240\354\240\200\355\236\210 \353\260\260\354\240\234\355\225\230\352\263\240, \352\271\224\353\201\224\355\225\234 \354\202\254\354\232\251\354\236\220 \355\231\230\352\262\275\354\235\204 \354\231\204\354\204\261\355\225\230\354\213\255\354\213\234\354\230\244.\n* **\354\202\254\354\232\251\354\236\220 \354\235\230\353\217\204 \354\264\210\352\263\274 \352\265\254\355\230\204 \352\270\210\354\247\200**: \354\202\254\354\232\251\354\236\220\352\260\200 \354\232\224\354\262\255\355\225\234 \354\212\244\354\275\224\355\224\204 \354\225\210\354\227\220\354\204\234\353\247\214 \354\240\225\352\265\220\355\225\230\352\263\240 \352\270\260\355\222\210 \354\236\210\353\212\224 \354\210\230\354\240\225\354\235\204 \352\260\200\355\225\230\352\263\240, \354\232\224\352\265\254\355\225\230\354\247\200 \354\225\212\354\235\200 \353\213\244\355\201\254\353\252\250\353\223\234 \355\206\240\352\270\200 \354\212\244\354\234\204\354\271\230\353\202\230 \353\213\244\353\245\270 \353\263\264\354\241\260 \354\260\250\355\212\270 \353\223\261\354\235\230 \352\270\260\353\212\245\354\235\204 \353\247\210\354\235\214\353\214\200\353\241\234 \354\266\224\352\260\200\355\225\230\354\227\254 \353\263\274\353\245\250\354\235\204 \353\212\230\353\246\254\354\247\200 \353\247\210\354\213\255\354\213\234\354\230\244. \354\236\245\354\235\270 \354\240\225\354\213\240\354\235\200 \352\270\260\353\212\245\354\235\230 \354\226\221\354\235\264 \354\225\204\353\213\214 \353\247\210\352\260\220\354\235\230 \355\200\204\353\246\254\355\213\260\354\227\220\354\204\234 \353\202\230\354\230\265\353\213\210\353\213\244.\n\n---\n\n## 5. \353\263\200\352\262\275 \353\260\217 \352\262\200\354\246\235 \355\224\204\353\241\234\354\204\270\354\212\244\n* \354\203\210\353\241\234\354\232\264 \352\270\260\353\212\245\354\235\264\353\202\230 \354\213\234\353\256\254\353\240\210\354\235\264\354\205\230 \354\203\201\355\203\234\352\260\200 \354\266\224\352\260\200\353\220\230\353\251\264 \353\260\230\353\223\234\354\213\234 React \354\270\241 \354\273\264\355\217\254\353\204\214\355\212\270(`App.tsx`, `PhoneSimulator.tsx`, `CodeViewer.tsx`)\354\231\200 \354\232\260\354\270\241 Kotlin \352\260\200\354\203\201 \354\275\224\353\223\234 \355\214\214\354\235\274 \353\202\264\354\235\230 \353\202\264\354\232\251\354\235\204 \355\225\250\352\273\230 \354\265\234\354\213\240\355\231\224\355\225\230\354\227\254 \353\252\250\354\210\234\354\235\264 \354\227\206\353\217\204\353\241\235 \355\225\264\354\225\274 \355\225\251\353\213\210\353\213\244.\n* \354\275\224\353\223\234 \354\210\230\354\240\225 \354\236\221\354\227\205\354\235\264 \353\201\235\353\202\240 \353\225\214\353\247\210\353\213\244 \353\260\230\353\223\234\354\213\234 `lint_applet`\352\263\274 `compile_applet`\354\235\204 \354\210\230\355\226\211\355\225\230\354\227\254 \353\271\214\353\223\234 \354\227\220\353\237\254 \353\260\217 \354\235\230\354\241\264\354\204\261 \353\254\270\354\240\234\352\260\200 \354\227\206\353\212\224\354\247\200 \352\262\200\354\246\235\355\225\230\354\213\255\354\213\234\354\230\244.\n"
    }
