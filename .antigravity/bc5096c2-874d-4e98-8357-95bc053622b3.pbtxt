          text: "* **\355\203\200\354\235\264\355\217\254\352\267\270\353\236\230\355\224\274**:"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  * \353\224\224\354\212\244\355\224\214\353\240\210\354\235\264 \353\260\217 \355\227\244\353\215\224 \354\230\201\354\227\255\354\227\220\353\212\224 \352\270\260\355\225\230\355\225\231\354\240\201\354\235\264\352\263\240 \355\230\204\353\214\200\354\240\201\354\235\270 \355\217\260\355\212\270 \352\265\265\352\270\260\353\245\274 \354\202\254\354\232\251\355\225\230\352\263\240, \354\275\224\353\223\234 \354\230\201\354\227\255\354\235\200 \354\235\274\352\264\200\353\220\234 \353\252\250\353\205\270\354\212\244\355\216\230\354\235\264\354\212\244(`font-mono`) \355\217\260\355\212\270\353\245\274 \354\202\254\354\232\251\355\225\251\353\213\210\353\213\244."
