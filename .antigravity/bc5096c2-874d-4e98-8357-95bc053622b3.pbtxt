        lines {
          text: "## 1. \355\224\204\353\241\234\354\240\235\355\212\270 \355\225\265\354\213\254 \353\252\251\354\240\201 \353\260\217 \354\240\225\354\262\264\354\204\261 (Identity)"
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
