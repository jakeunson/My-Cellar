        lines {
          text: "\354\235\264 \355\214\214\354\235\274\354\235\200 **Jetpack Compose \354\243\274\353\245\230 \355\205\214\354\235\264\354\212\244\355\214\205 \354\240\200\353\204\220 (Liquor Tasting Journal)** \355\224\204\353\241\234\354\240\235\355\212\270\353\245\274 \354\234\204\355\225\234 AI \354\275\224\353\224\251 \354\227\220\354\235\264\354\240\204\355\212\270 \354\240\204\354\232\251 \354\247\200\354\271\250 \353\260\217 \355\226\211\353\217\231 \352\267\234\354\271\231 \353\254\270\354\204\234\354\236\205\353\213\210\353\213\244. \354\227\220\354\235\264\354\240\204\355\212\270\353\212\224 \355\226\245\355\233\204 \354\235\264 \355\224\204\353\241\234\354\240\235\355\212\270\354\235\230 \354\275\224\353\223\234\353\245\274 \354\210\230\354\240\225\355\225\230\352\261\260\353\202\230 \352\270\260\353\212\245\354\235\204 \354\266\224\352\260\200\355\225\240 \353\225\214 \354\225\204\353\236\230\354\235\230 \352\267\234\354\271\231\354\235\204 \354\227\204\352\262\251\355\236\210 \354\244\200\354\210\230\355\225\264\354\225\274 \355\225\251\353\213\210\353\213\244."
