        lines {
          text: "  * \355\225\234\352\265\255\354\226\264 \355\205\215\354\212\244\355\212\270\354\231\200 \352\260\200\353\217\205\354\204\261 \354\236\210\353\212\224 \355\217\260\355\212\270 \354\212\244\354\274\200\354\235\274\353\247\201, \354\266\251\353\266\204\355\225\234 \354\227\254\353\260\261 \353\260\217 \353\214\200\353\271\204(Contrast)\353\245\274 \355\231\225\353\263\264\355\225\230\354\227\254 \355\203\201\354\233\224\355\225\234 \354\213\234\352\260\201\354\240\201 \354\231\204\354\204\261\353\217\204\353\245\274 \354\240\234\352\263\265\355\225\251\353\213\210\353\213\244."
