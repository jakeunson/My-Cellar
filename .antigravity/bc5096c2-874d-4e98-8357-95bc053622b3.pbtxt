      target_content: "  return (\n    <div className=\"bg-neutral-900 border border-neutral-800 rounded-3xl overflow-hidden flex flex-col h-full shadow-2xl\">\n      {/* IDE Header */}\n      <div className=\"bg-neutral-950/70 px-6 py-4 flex flex-col md:flex-row md:items-center justify-between border-b border-neutral-800 gap-4\">\n        <div className=\"flex items-center space-x-3\">\n          <div className=\"p-2 bg-amber-500/10 rounded-xl\">\n            <FileCode className=\"w-5 h-5 text-amber-500\" />\n          </div>\n          <div>\n            <div className=\"flex items-center space-x-2\">\n              <span className=\"font-bold text-amber-100 text-sm\">{activeFile.name}</span>\n              <span className=\"text-[10px] bg-neutral-800 text-amber-400/80 px-2 py-0.5 rounded border border-neutral-700 font-mono\">Kotlin</span>\n            </div>\n            <p className=\"text-xs text-neutral-400 mt-0.5\">{activeFile.description}</p>\n          </div>\n        </div>\n \n        {/* Action Buttons */}\n        <div className=\"flex items-center space-x-2 shrink-0\">\n          <button\n            onClick={handleCopy}\n            className=\"flex items-center space-x-1.5 px-3 py-2 bg-neutral-800 hover:bg-neutral-700 text-neutral-200 hover:text-white rounded-xl text-xs font-semibold transition-colors border border-neutral-700/60\"\n          >\n            {copied ? (\n              <>\n                <Check className=\"w-3.5 h-3.5 text-emerald-400\" />\n                <span className=\"text-emerald-400\">\353\263\265\354\202\254\353\220\250!</span>\n              </>\n            ) : (\n              <>\n                <Copy className=\"w-3.5 h-3.5\" />\n                <span>\354\275\224\353\223\234 \353\263\265\354\202\254</span>\n              </>\n            )}\n          </button>\n          \n          <button\n            onClick={handleDownloadFile}\n            className=\"flex items-center space-x-1.5 px-3 py-2 bg-amber-600 hover:bg-amber-500 text-neutral-950 rounded-xl text-xs font-bold transition-colors shadow-md\"\n          >\n            <Download className=\"w-3.5 h-3.5\" />\n            <span>\354\235\264 \355\214\214\354\235\274 \353\213\244\354\232\264\353\241\234\353\223\234</span>\n          </button>\n        </div>\n      </div>\n \n      {/* File Tabs */}\n      <div className=\"bg-neutral-950 px-4 pt-2 flex space-x-1 overflow-x-auto border-b border-neutral-900 scrollbar-none\">\n        {files.map((file) => (\n          <button\n            key={file.name}\n            onClick={() => onSelectFile(file.name)}\n            className={`px-4 py-2 text-xs font-medium rounded-t-xl transition-all border-t border-x ${\n              selectedFileName === file.name\n                ? \'bg-neutral-900 border-neutral-800 text-amber-400 font-bold\'\n                : \'bg-neutral-950 border-transparent text-neutral-400 hover:text-neutral-200\'\n            }`}\n          >\n            <span className=\"mr-1.5 text-[10px]\">\342\230\225</span>\n            {file.name}\n          </button>\n        ))}\n      </div>\n \n      {/* Sync banner/info if mapping exists */}\n      {mapping && (\n        <div className=\"bg-amber-950/20 border-b border-amber-900/10 px-6 py-2 flex items-center justify-between text-xs text-amber-200/80\">\n          <div className=\"flex items-center space-x-1.5\">\n            <Sparkles className=\"w-3.5 h-3.5 text-amber-500\" />\n            <span>\354\235\264 \354\275\224\353\223\234\353\212\224 \354\213\234\353\256\254\353\240\210\354\235\264\355\204\260\354\235\230 <strong>{mapping.name}</strong>\354\227\220 \355\225\264\353\213\271\355\225\251\353\213\210\353\213\244.</span>\n          </div>\n          <button\n            onClick={() => onSyncSimulator(mapping.screen)}\n            className=\"text-[10px] bg-amber-500/10 hover:bg-amber-500/20 border border-amber-500/20 text-amber-400 px-2 py-0.5 rounded-lg transition-colors font-medium\"\n          >\n          