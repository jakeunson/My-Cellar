        lines {
          text: "  * \354\260\250\353\266\204\355\225\234 **Slate(\355\232\214\354\203\211/\353\202\250\354\203\211 \352\263\204\354\227\264)** \354\272\224\353\262\204\354\212\244\354\231\200 \352\277\200\353\271\233 \354\234\204\354\212\244\355\202\244 \352\263\250\353\223\234 \353\260\217 \354\260\270\353\202\230\353\254\264 \352\260\210\354\203\211\354\235\270 **Amber/Oak** \352\263\204\354\227\264 \354\225\205\354\204\274\355\212\270 \354\273\254\353\237\254\352\260\200 \354\241\260\355\231\224\353\241\255\352\262\214 \353\205\271\354\225\204\353\223\240 \352\263\240\353\214\200\353\271\204 \353\235\274\354\235\264\355\212\270/\353\204\244\354\266\224\353\237\264 \354\212\244\355\203\200\354\235\274\354\235\204 \354\234\240\354\247\200\355\225\251\353\213\210\353\213\244."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
        lines {
          text: "  * \352\262\254\352\263\240\355\225\234 \352\270\260\355\225\230\355\225\231\354\240\201 \355\230\225\355\203\234\354\235\230 \352\265\265\354\235\200 \353\263\264\353\215\224\353\235\274\354\235\270(Slate-900 \354\234\204\354\243\274\354\235\230 \355\205\214\353\221\220\353\246\254, `border-4` \353\223\261)\352\263\274 \352\260\234\354\204\261 \354\236\210\353\212\224 \353\257\270\353\213\210\353\251\200/\353\204\244\354\230\244\353\270\214\353\243\250\355\203\210\353\246\254\354\246\230 \353\224\224\354\236\220\354\235\270 \354\225\204\354\235\264\353\215\264\355\213\260\355\213\260\353\245\274 \353\263\264\354\241\264\355\225\251\353\213\210\353\213\244."
          type: UNIFIED_DIFF_LINE_TYPE_UNCHANGED
        }
