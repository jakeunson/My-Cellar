        lines {
          text: "* **\353\252\251\354\240\201**: \354\235\264 \354\225\261\354\235\200 \354\225\210\353\223\234\353\241\234\354\235\264\353\223\234 **Material Design 3 (M3)** \353\260\217 **Jetpack Compose**\353\245\274 \352\270\260\353\260\230\354\234\274\353\241\234 \354\236\221\353\217\231\355\225\230\353\212\224 \354\243\274\353\245\230 \355\205\214\354\235\264\354\212\244\355\214\205 \354\240\200\353\204\220 \354\225\261\354\235\230 \352\265\254\354\241\260 \354\204\244\352\263\204, \355\231\224\353\251\264 \355\235\220\353\246\204 \354\213\234\353\256\254\353\240\210\354\235\264\354\205\230 \353\260\217 \354\213\244\354\240\234 \353\271\214\353\223\234 \352\260\200\353\212\245\355\225\234 \354\275\224\355\213\200\353\246\260(Kotlin) \354\275\224\353\223\234\353\245\274 \354\240\234\352\263\265\355\225\230\353\212\224 \355\206\265\355\225\251 \353\217\204\352\265\254\354\236\205\353\213\210\353\213\244."
