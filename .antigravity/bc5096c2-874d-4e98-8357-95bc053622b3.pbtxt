      replacement_content: "import React, { useState, useEffect } from \'react\';\nimport { motion, AnimatePresence } from \'motion/react\';\nimport { \n  Plus, Search, Star, Trash2, ArrowLeft, Check, \n  Wifi, Battery, ShieldAlert, AlertTriangle, Calendar, Award \n} from \'lucide-react\';\nimport { TastingEntry, LiquorCategory } from \'../types\';\n\ninterface PhoneSimulatorProps {\n  entries: TastingEntry[];\n  onAddEntry: (entry: TastingEntry) => void;\n  onDeleteEntry: (id: string) => void;\n  currentScreen: string;\n  onScreenChange: (screen: string) => void;\n}\n\nexport default function PhoneSimulator({\n  entries,\n  onAddEntry,\n  onDeleteEntry,\n  currentScreen,\n  onScreenChange\n}: PhoneSimulatorProps) {\n  // Simulator internal state\n  const [activeTab, setActiveTab] = useState<LiquorCategory | \'ALL\'>(\'ALL\');\n  const [searchQuery, setSearchQuery] = useState(\'\');\n  const [selectedEntryId, setSelectedEntryId] = useState<string | null>(null);\n  \n  // Form state\n  const [formName, setFormName] = useState(\'\');\n  const [formCategory, setFormCategory] = useState<LiquorCategory>(\'Whiskey\');\n  const [formAbv, setFormAbv] = useState<string>(\'\');\n  const [formRating, setFormRating] = useState<number>(3);\n  const [formNotes, setFormNotes] = useState(\'\');\n  const [formSweet, setFormSweet] = useState<number>(2);\n  const [formBitter, setFormBitter] = useState<number>(2);\n  const [formSour, setFormSour] = useState<number>(2);\n  const [formBody, setFormBody] = useState<number>(3);\n  const [formSmoky, setFormSmoky] = useState<number>(1);\n  const [formError, setFormError] = useState(\'\');\n\n  // Auto-sync tab view in IDE when user interacts with screens\n  useEffect(() => {\n    if (currentScreen === \'home\') {\n      onScreenChange(\'TastingListScreen.kt\');\n    } else if (currentScreen === \'add\') {\n      onScreenChange(\'TastingFormScreen.kt\');\n    } else if (currentScreen === \'detail\') {\n      onScreenChange(\'TastingDetailScreen.kt\');\n    }\n  }, [currentScreen]);\n\n  const selectedEntry = entries.find(e => e.id === selectedEntryId);\n\n  // Filter listings\n  const filteredEntries = entries.filter(entry => {\n    const matchesSearch = entry.name.toLowerCase().includes(searchQuery.toLowerCase()) ||\n                          entry.notes.toLowerCase().includes(searchQuery.toLowerCase());\n    const matchesCategory = activeTab === \'ALL\' || entry.category === activeTab;\n    return matchesSearch && matchesCategory;\n  });\n\n  // Handle saving\n  const handleSave = () => {\n    if (!formName.trim()) {\n      setFormError(\'\354\210\240 \354\235\264\353\246\204\354\235\204 \354\236\205\353\240\245\355\225\264 \354\243\274\354\204\270\354\232\224.\');\n      return;\n    }\n    const abvVal = parseFloat(formAbv) || 0;\n    const today = new Date().toISOString().split(\'T\')[0];\n\n    const newEntry: TastingEntry = {\n      id: Math.random().toString(36).substring(2, 9),\n      name: formName,\n      category: formCategory,\n      abv: abvVal,\n      rating: formRating,\n      date: today,\n      notes: formNotes,\n      flavors: {\n        sweet: formSweet,\n        bitter: formBitter,\n        sour: formSour,\n        body: formBody,\n        smoky: formSmoky\n      }\n    };\n\n    onAddEntry(newEntry);\n    \n    // Reset Form & Go Back\n    setFormName(\'\');\n    setFormAbv(\'\');\n    setFormRating(3);\n    setFormNotes(\'\');\n    setFormSweet(2);\n    setFormBitter(2);\n    setFormSour(2);\n    setFormBody(3);\n    setFormSmoky(1);\n    setFormError(\'\');\n    onScreenChange(\'TastingListScreen.kt\');\n  };\n\n  const getCategoryEmoji = (cat: LiquorCategory) => {\n    switch (cat) {\n      case \'Whiskey\': return \'\360\237\245\203\';\n      case \'Wine\': return \'\360\237\215\267\';\n      case \'Beer\': return \'\360\237\215\272\';\n      case \'Sake\': return \'\360\237\215\266\';\n      case \'Korean\': return \'\360\237\215\266\';\n      case \'Cocktail\': return \'\360\237\215\270\';\n      case \'Other\': return \'\360\237\215\271\';\n    }\n  };\n\n  const getCategoryName = (cat: LiquorCategory) => {\n    switch (cat) {\n      case \'Whiskey\': return \'\354\234\204\354\212\244\355\202\244\';\n      case \'Wine\': return \'\354\231\200\354\235\270\';\n      case \'Beer\': return \'\353\247\245\354\243\274\';\n      case \'Sake\': return \'\354\202\254\354\274\200\';\n      case \'Korean\': return \'\354\240\204\355\206\265\354\243\274\';\n      case \'Cocktail\': return \'\354\271\265\355\205\214\354\235\274\';\n      case \'Other\': return \'\352\270\260\355\203\200\';\n    }\n  };\n\n  const categories: (LiquorCategory | \'ALL\')[] = [\'ALL\', \'Whiskey\', \'Wine\', \'Beer\', \'Korean\', \'Sake\', \'Cocktail\', \'Other\'];\n\n  return (\n    <div className=\"flex flex-col items-center\">\n      {/* Device wrapper */}\n      <div className=\"relative w-[340px] h-[680px] bg-amber-950/20 border-8 border-neutral-900 rounded-[44px] shadow-2xl overflow-hidden flex flex-col ring-4 ring-amber-500/10\">\n        {/* Notch / Speaker */}\n        <div className=\"absolute top-0 left-1/2 -translate-x-1/2 w-32 h-6 bg-neutral-900 rounded-b-2xl z-50 flex items-center justify-center\">\n          <div className=\"w-12 h-1 bg-neutral-800 rounded-full mb-1\"></div>\n        </div>\n\n        {/* Status Bar */}\n        <div className=\"h-7 bg-amber-950/40 text-[11px] text-amber-200/90 px-6 pt-1 flex items-center justify-between font-medium select-none z-40 shrink-0\">\n          <span>09:41</span>\n          <div className=\"flex items-center space-x-1.5\">\n            <Wifi className=\"w-3.5 h-3.5\" />\n            <span className=\"text-[9px]\">5G</span>\n            <Battery className=\"w-4 h-4\" />\n          </div>\n        </div>\n\n        {/* App Main Area */}\n        <div className=\"flex-1 flex flex-col bg-neutral-950 overflow-hidden relative text-amber-100\">\n          \n          <AnimatePresence mode=\"wait\">\n            {/* SCREEN 1: LIST / HOME */}\n            {currentScreen === \'home\' && (\n              <motion.div \n                key=\"home\"\n                initial={{ opacity: 0, x: -10 }}\n                animate={{ opacity: 1, x: 0 }}\n                exit={{ opacity: 0, x: 10 }}\n                className=\"flex-1 flex flex-col h-full overflow-hidden\"\n              >\n                {/* Simulated App Bar */}\n                <div className=\"bg-amber-950/30 border-b border-amber-900/30 px-4 py-3 shrink-0\">\n                  <h1 className=\"text-lg font-bold text-amber-300 tracking-tight\">\353\202\230\354\235\230 \354\243\274\353\245\230 \355\205\214\354\235\264\354\212\244\355\214\205 \354\240\200\353\204\220</h1>\n                  <p className=\"text-[10px] text-amber-400/60 mt-0.5\">\354\225\210\353\223\234\353\241\234\354\235\264\353\223\234 \354\225\261 \352\260\200\354\203\201 \354\213\234\353\256\254\353\240\210\354\235\264\355\204\260</p>\n                </div>\n\n                {/* Scrollable Content inside Phone */}\n                <div className=\"flex-1 overflow-y-auto px-4 py-3 space-y-4 pb-20 custom-scrollbar\">\n                  {/* Search Bar */}\n                  <div className=\"relative\">\n                    <Search className=\"w-4 h-4 text-amber-500/60 absolute left-3 top-2.5\" />\n                    <input \n                      type=\"text\" \n                      placeholder=\"\354\210\240 \354\235\264\353\246\204, \355\205\214\354\235\264\354\212\244\355\214\205 \352\270\260\353\241\235 \352\262\200\354\203\211...\" \n                      value={searchQuery}\n                      onChange={(e) => setSearchQuery(e.target.value)}\n                      className=\"w-full bg-amber-950/20 border border-amber-900/40 rounded-xl py-2 pl-9 pr-4 text-xs text-amber-100 placeholder-amber-700/60 focus:outline-none focus:ring-1 focus:ring-amber-500/50\"\n                    />\n                  </div>\n\n                  {/* Horizontal Scroll Filter Chips */}\n                  <div className=\"flex space-x-1.5 overflow-x-auto pb-1 scrollbar-none shrink-0 select-none\">\n                    {categories.map((cat) => (\n                      <button\n                        key={cat}\n                        onClick={() => setActiveTab(cat)}\n                        className={`px-3 py-1.5 rounded-full text-[10px] font-semibold whitespace-nowrap transition-colors ${\n                          activeTab === cat \n                            ? \'bg-amber-600 text-neutral-950 shadow-md\' \n                            : \'bg-neutral-900 text-amber-500/80 hover:bg-amber-950/30 border border-amber-900/20\'\n                        }`}\n                      >\n                        {cat === \'ALL\' ? \'\354\240\204\354\262\264\' : `${getCategoryEmoji(cat)} ${getCategoryName(cat)}`}\n                      </button>\n                    ))}\n                  </div>\n\n                  {/* Tasting List */}\n                  <div className=\"space-y-3\">\n                    {filteredEntries.length === 0 ? (\n                      <div className=\"text-center py-12 text-amber-700/60 text-xs\">\n                        {searchQuery || activeTab !== \'ALL\' ? (\n                          <span>\354\241\260\352\261\264\354\227\220 \353\247\236\353\212\224 \352\270\260\353\241\235\354\235\264 \354\227\206\354\212\265\353\213\210\353\213\244.</span>\n                        ) : (\n                          <span>\354\236\221\354\204\261\353\220\234 \355\205\214\354\235\264\354\212\244\355\214\205 \352\270\260\353\241\235\354\235\264 \354\227\206\354\212\265\353\213\210\353\213\244.<br/>\354\232\260\354\270\241 \355\225\230\353\213\250 \'+\' \353\262\204\355\212\274\354\234\274\353\241\234 \354\262\253 \352\270\260\353\241\235\354\235\204 \353\202\250\352\262\250\353\263\264\354\204\270\354\232\224!</span>\n                        )}\n                      </div>\n                    ) : (\n                      filteredEntries.map((entry) => (\n                        <div \n                          key={entry.id}\n                          id={`tasting-item-${entry.id}`}\n                          onClick={() => {\n                            setSelectedEntryId(entry.id);\n                            onScreenChange(\'detail\');\n                          }}\n                          className=\"bg-neutral-900/90 border border-amber-950/40 hover:border-amber-700/40 rounded-2xl p-3.5 transition-all cursor-pointer flex items-center space-x-3 shadow-md hover:shadow-amber-950/20\"\n                        >\n                          <div className=\"w-11 h-11 rounded-xl bg-amber-950/55 flex items-center justify-center text-xl shrink-0 border border-amber-900/30\">\n                            {getCategoryEmoji(entry.category)}\n                          </div>\n                          <div className=\"flex-1 min-w-0\">\n                            <div className=\"flex items-center justify-between\">\n                              <h3 className=\"text-xs font-bold text-amber-100 truncate pr-2\">{entry.name}</h3>\n                              <span className=\"text-[10px] font-semibold text-amber-500 shrink-0\">{entry.abv}%</span>\n                            </div>\n                            <div className=\"flex items-center space-x-2 text-[9px] text-amber-400/60 mt-0.5\">\n                              <span>{getCategoryName(entry.category)}</span>\n                              <span>\342\200\242</span>\n                              <span>{entry.date}</span>\n                            </div>\n                            <div className=\"flex items-center mt-1.5\">\n                              {Array.from({ length: 5 }).map((_, i) => (\n                                <Star \n                                  key={i} \n                                  className={`w-3 h-3 ${i < entry.rating ? \'text-amber-400 fill-amber-400\' : \'text-neutral-700\'}`} \n                                />\n                              ))}\n                            </div>\n                          </div>\n                        </div>\n                      ))\n                    )}\n                  </div>\n                </div>\n\n                {/* Floating Action Button (FAB) */}\n                <button\n                  id=\"fab-add-tasting\"\n                  onClick={() => onScreenChange(\'add\')}\n                  className=\"absolute bottom-6 right-6 w-12 h-12 bg-amber-500 hover:bg-amber-600 text-neutral-950 rounded-full flex items-center justify-center shadow-lg hover:scale-105 active:scale-95 transition-all z-30\"\n                >\n                  <Plus className=\"w-6 h-6 stroke-[2.5]\" />\n                </button>\n              </motion.div>\n            )}\n\n            {/* SCREEN 2: ADD FORM */}\n            {currentScreen === \'add\' && (\n              <motion.div \n                key=\"add\"\n                initial={{ opacity: 0, x: 10 }}\n                animate={{ opacity: 1, x: 0 }}\n                exit={{ opacity: 0, x: -10 }}\n                className=\"flex-1 flex flex-col h-full overflow-hidden\"\n              >\n                {/* App Bar */}\n                <div className=\"bg-amber-950/30 border-b border-amber-900/30 px-3 py-3 flex items-center space-x-2 shrink-0 justify-between\">\n                  <div className=\"flex items-center space-x-2\">\n                    <button \n                      onClick={() => onScreenChange(\'home\')}\n                      className=\"p-1 hover:bg-amber-950/40 rounded-full transition-colors text-amber-300\"\n                    >\n                      <ArrowLeft className=\"w-4 h-4\" />\n                    </button>\n                    <h1 className=\"text-xs font-bold text-amber-200\">\354\203\210\353\241\234\354\232\264 \355\205\214\354\235\264\354\212\244\355\214\205 \354\236\221\354\204\261</h1>\n                  </div>\n                  <button \n                    onClick={handleSave}\n                    className=\"text-[11px] font-bold text-amber-400 hover:text-amber-300 px-2 py-1 bg-amber-950/50 border border-amber-900/50 rounded-lg transition-colors flex items-center space-x-1\"\n                  >\n                    <Check className=\"w-3 h-3\" />\n                    <span>\354\231\204\353\243\214</span>\n                  </button>\n                </div>\n\n                {/* Form Fields container */}\n                <div className=\"flex-1 overflow-y-auto px-4 py-4 space-y-4 pb-20 custom-scrollbar text-xs\">\n                  {formError && (\n                    <div className=\"bg-red-950/30 border border-red-900/50 rounded-xl p-2.5 flex items-center space-x-2 text-red-300 text-[10px]\">\n                      <AlertTriangle className=\"w-4 h-4 shrink-0\" />\n                      <span>{formError}</span>\n                    </div>\n                  )}\n\n                  {/* 1. \354\210\240 \354\235\264\353\246\204 */}\n                  <div className=\"space-y-1\">\n                    <label className=\"text-[10px] font-bold text-amber-500 uppercase tracking-wider\">\354\243\274\353\245\230 \354\235\264\353\246\204 *</label>\n                    <input \n                      type=\"text\"\n                      placeholder=\"\354\230\210: \353\260\234\353\262\240\353\213\210 12\353\205\204 \353\215\224\353\270\224\354\232\260\353\223\234, \353\217\224 \355\216\230\353\246\254\353\207\275...\"\n                      value={formName}\n                      onChange={(e) => {\n                        setFormName(e.target.value);\n                        if (e.target.value) setFormError(\'\');\n                      }}\n                      className=\"w-full bg-neutral-900 border border-amber-900/30 rounded-xl py-2 px-3 text-xs text-amber-100 placeholder-amber-800/40 focus:outline-none focus:border-amber-500\"\n                    />\n                  </div>\n\n                  {/* 2. \354\271\264\355\205\214\352\263\240\353\246\254 (Grid) */}\n                  <div className=\"space-y-1\">\n                    <label className=\"text-[10px] font-bold text-amber-500 uppercase tracking-wider block mb-1\">\354\271\264\355\205\214\352\263\240\353\246\254</label>\n                    <div className=\"grid grid-cols-3 gap-1.5\">\n                      {categories.filter(c => c !== \'ALL\').map((cat) => (\n                        <button\n                          key={cat}\n                          type=\"button\"\n                          onClick={() => setFormCategory(cat as LiquorCategory)}\n                          className={`py-1.5 rounded-lg text-[9px] font-semibold transition-all border ${\n                            formCategory === cat \n                              ? \'bg-amber-950/60 border-amber-500 text-amber-300\' \n                              : \'bg-neutral-900 border-amber-900/15 text-amber-500/60 hover:border-amber-900/40\'\n                          }`}\n                        >\n                          <span className=\"mr-0.5\">{getCategoryEmoji(cat as LiquorCategory)}</span>\n                          <span>{getCategoryName(cat as LiquorCategory)}</span>\n                        </button>\n                      ))}\n                    </div>\n                  </div>\n\n                  {/* 3. ABV \353\217\204\354\210\230 & Rating (\354\210\230\355\217\211 \353\260\260\354\271\230) */}\n                  <div className=\"grid grid-cols-2 gap-4\">\n                    <div className=\"space-y-1\">\n                      <label className=\"text-[10px] font-bold text-amber-500 uppercase tracking-wider\">\354\225\214\354\275\224\354\230\254 \353\217\204\354\210\230 (%)</label>\n                      <input \n                        type=\"number\"\n                        step=\"0.1\"\n                        placeholder=\"\354\230\210: 40\"\n                        value={formAbv}\n                        onChange={(e) => setFormAbv(e.target.value)}\n                        className=\"w-full bg-neutral-900 border border-amber-900/30 rounded-xl py-2 px-3 text-xs text-amber-100 placeholder-amber-800/40 focus:outline-none focus:border-amber-500\"\n                      />\n                    </div>\n                    <div className=\"space-y-1\">\n                      <label className=\"text-[10px] font-bold text-amber-500 uppercase tracking-wider block\">\353\247\214\354\241\261\353\217\204 \353\263\204\354\240\220</label>\n                      <div className=\"flex items-center space-x-1 py-1.5\">\n                        {Array.from({ length: 5 }).map((_, i) => (\n                          <button\n                            key={i}\n                            type=\"button\"\n                            onClick={() => setFormRating(i + 1)}\n                            className=\"p-0.5 focus:outline-none\"\n                          >\n                            <Star \n                              className={`w-5 h-5 ${i < formRating ? \'text-amber-400 fill-amber-400\' : \'text-neutral-700 hover:text-amber-700\'}`} \n                            />\n                          </button>\n                        ))}\n                      </div>\n                    </div>\n                  </div>\n\n                  <hr className=\"border-amber-900/20\" />\n\n                  {/* 4. \354\230\244\352\260\201\355\230\225 \354\204\270\353\266\200 \353\247\233 \355\217\211\352\260\200 */}\n                  <div className=\"space-y-2.5\">\n                    <h3 className=\"text-[10px] font-bold text-amber-400 uppercase tracking-wider\">\353\247\233 & \355\226\245\353\257\270 \355\224\204\353\241\234\355\225\204 (0-5\354\240\220)</h3>\n                    \n                    {/* Sweet */}\n                    <div className=\"flex items-center justify-between text-[10px]\">\n                      <span className=\"w-16 font-semibold text-amber-500/80\">\353\213\250\353\247\233 (Sweet)</span>\n                      <input \n                        type=\"range\" min=\"0\" max=\"5\" value={formSweet} \n                        onChange={(e) => setFormSweet(parseInt(e.target.value))}\n                        className=\"flex-1 mx-3 accent-amber-500 h-1 bg-amber-950/50 rounded-lg appearance-none cursor-pointer\"\n                      />\n                      <span className=\"w-6 text-right font-bold text-amber-300\">{formSweet}\354\240\220</span>\n                    </div>\n\n                    {/* Bitter */}\n                    <div className=\"flex items-center justify-between text-[10px]\">\n                      <span className=\"w-16 font-semibold text-amber-500/80\">\354\223\264\353\247\233 (Bitter)</span>\n                      <input \n                        type=\"range\" min=\"0\" max=\"5\" value={formBitter} \n                        onChange={(e) => setFormBitter(parseInt(e.target.value))}\n                        className=\"flex-1 mx-3 accent-amber-500 h-1 bg-amber-950/50 rounded-lg appearance-none cursor-pointer\"\n                      />\n                      <span className=\"w-6 text-right font-bold text-amber-300\">{formBitter}\354\240\220</span>\n                    </div>\n\n                    {/* Sour */}\n                    <div className=\"flex items-center justify-between text-[10px]\">\n                      <span className=\"w-16 font-semibold text-amber-500/80\">\354\213\240\353\247\233 (Sour)</span>\n                      <input \n                        type=\"range\" min=\"0\" max=\"5\" value={formSour} \n                        onChange={(e) => setFormSour(parseInt(e.target.value))}\n                        className=\"flex-1 mx-3 accent-amber-500 h-1 bg-amber-950/50 rounded-lg appearance-none cursor-pointer\"\n                      />\n                      <span className=\"w-6 text-right font-bold text-amber-300\">{formSour}\354\240\220</span>\n                    </div>\n\n                    {/* Body */}\n                    <div className=\"flex items-center justify-between text-[10px]\">\n                      <span className=\"w-16 font-semibold text-amber-500/80\">\353\260\224\353\224\224\352\260\220 (Body)</span>\n                      <input \n                        type=\"range\" min=\"0\" max=\"5\" value={formBody} \n                        onChange={(e) => setFormBody(parseInt(e.target.value))}\n                        className=\"flex-1 mx-3 accent-amber-500 h-1 bg-amber-950/50 rounded-lg appearance-none cursor-pointer\"\n                      />\n                      <span className=\"w-6 text-right font-bold text-amber-300\">{formBody}\354\240\220</span>\n                    </div>\n\n                    {/* Smoky */}\n                    <div className=\"flex items-center justify-between text-[10px]\">\n                      <span className=\"w-16 font-semibold text-amber-500/80\">\354\212\244\353\252\250\355\202\244\355\225\250</span>\n                      <input \n                        type=\"range\" min=\"0\" max=\"5\" value={formSmoky} \n                        onChange={(e) => setFormSmoky(parseInt(e.target.value))}\n                        className=\"flex-1 mx-3 accent-amber-500 h-1 bg-amber-950/50 rounded-lg appearance-none cursor-pointer\"\n                      />\n                      <span className=\"w-6 text-right font-bold text-amber-300\">{formSmoky}\354\240\220</span>\n                    </div>\n                  </div>\n\n                  <hr className=\"border-amber-900/20\" />\n\n                  {/* 5. \354\213\234\354\235\214 \353\205\270\355\212\270 */}\n                  <div className=\"space-y-1\">\n                    <label className=\"text-[10px] font-bold text-amber-500 uppercase tracking-wider\">\353\251\224\353\252\250 & \354\213\234\354\235\214 \355\217\211</label>\n                    <textarea \n                      placeholder=\"\355\226\245, \353\247\233, \353\252\251\353\204\230\352\271\200, \355\224\274\353\213\210\354\213\234 \353\223\261\354\235\204 \354\236\220\354\234\240\353\241\255\352\262\214 \354\240\201\354\226\264\354\243\274\354\204\270\354\232\224...\"\n                      value={formNotes}\n                      rows={4}\n                      onChange={(e) => setFormNotes(e.target.value)}\n                      className=\"w-full bg-neutral-900 border border-amber-900/30 rounded-xl py-2 px-3 text-xs text-amber-100 placeholder-amber-800/40 focus:outline-none focus:border-amber-500 resize-none\"\n                    />\n                  </div>\n\n                  {/* Submit Button */}\n                  <button\n                    type=\"button\"\n                    onClick={handleSave}\n                    className=\"w-full bg-amber-500 hover:bg-amber-600 active:scale-95 text-neutral-950 py-2.5 rounded-xl font-bold transition-all text-xs shadow-md mt-2\"\n                  >\n                    \352\270\260\353\241\235 \354\231\204\353\243\214\355\225\230\352\270\260\n                  </button>\n                </div>\n              </motion.div>\n            )}\n\n            {/* SCREEN 3: DETAIL VIEW */}\n            {currentScreen === \'detail\' && selectedEntry && (\n              <motion.div \n                key=\"detail\"\n                initial={{ opacity: 0, x: 10 }}\n                animate={{ opacity: 1, x: 0 }}\n                exit={{ opacity: 0, x: -10 }}\n                className=\"flex-1 flex flex-col h-full overflow-hidden\"\n              >\n                {/* App Bar */}\n                <div className=\"bg-amber-950/30 border-b border-amber-900/30 px-3 py-3 flex items-center space-x-2 shrink-0 justify-between\">\n                  <div className=\"flex items-center space-x-2\">\n                    <button \n                      onClick={() => onScreenChange(\'home\')}\n                      className=\"p-1 hover:bg-amber-950/40 rounded-full transition-colors text-amber-300\"\n                    >\n                      <ArrowLeft className=\"w-4 h-4\" />\n                    </button>\n                    <h1 className=\"text-xs font-bold text-amber-200\">\354\213\234\354\235\214 \354\203\201\354\204\270 \353\246\254\353\267\260</h1>\n                  </div>\n                  <button \n                    onClick={() => {\n                      if (confirm(\'\354\235\264 \355\205\214\354\235\264\354\212\244\355\214\205 \353\205\270\355\212\270\353\245\274 \354\240\225\353\247\220 \354\202\255\354\240\234\355\225\230\354\213\234\352\262\240\354\212\265\353\213\210\352\271\214?\')) {\n                        onDeleteEntry(selectedEntry.id);\n                        onScreenChange(\'home\');\n                      }\n                    }}\n                    className=\"p-1.5 hover:bg-red-950/40 rounded-full transition-colors text-red-400 hover:text-red-300\"\n                  >\n                    <Trash2 className=\"w-4 h-4\" />\n                  </button>\n                </div>\n\n                {/* Detail View Contents */}\n                <div className=\"flex-1 overflow-y-auto px-4 py-4 space-y-4 pb-16 custom-scrollbar text-xs\">\n                  \n                  {/* Hero Badge */}\n                  <div className=\"bg-amber-950/20 border border-amber-900/40 rounded-2xl p-4 text-center flex flex-col items-center shadow-lg relative overflow-hidden\">\n                    <div className=\"absolute top-0 right-0 w-20 h-20 bg-amber-500/5 rounded-full blur-xl\"></div>\n                    <span className=\"text-4xl filter drop-shadow mb-2 select-none\">\n                      {getCategoryEmoji(selectedEntry.category)}\n                    </span>\n                    <h2 className=\"text-sm font-black text-amber-100 tracking-tight\">{selectedEntry.name}</h2>\n                    \n                    <div className=\"flex space-x-2 mt-2 select-none\">\n                      <span className=\"bg-amber-900/40 text-amber-300 px-2 py-0.5 rounded-full text-[9px] font-semibold border border-amber-800/30\">\n                        {getCategoryName(selectedEntry.category)}\n                      </span>\n                      <span className=\"bg-amber-900/40 text-amber-300 px-2 py-0.5 rounded-full text-[9px] font-semibold border border-amber-800/30\">\n                        ABV {selectedEntry.abv}%\n                      </span>\n                    </div>\n\n                    {/* Star Row */}\n                    <div className=\"flex items-center space-x-0.5 mt-3\">\n                      {Array.from({ length: 5 }).map((_, i) => (\n                        <Star \n                          key={i} \n                          className={`w-4 h-4 ${i < selectedEntry.rating ? \'text-amber-400 fill-amber-400\' : \'text-neutral-800\'}`} \n                        />\n                      ))}\n                    </div>\n\n                    <div className=\"flex items-center space-x-1.5 mt-2.5 text-[9px] text-amber-500/60 font-medium\">\n                      <Calendar className=\"w-3 h-3\" />\n                      <span>\352\270\260\353\241\235\354\235\274: {selectedEntry.date}</span>\n                    </div>\n                  </div>\n\n                  {/* Flavor Spectrums */}\n                  <div className=\"bg-neutral-900/80 border border-amber-950/40 rounded-2xl p-3.5 space-y-3 shadow-md\">\n                    <h3 className=\"text-[10px] font-bold text-amber-400 uppercase tracking-wider flex items-center space-x-1\">\n                      <Award className=\"w-3.5 h-3.5 text-amber-400\" />\n                      <span>\355\226\245\353\257\270 \353\247\233 \354\212\244\355\216\231\355\212\270\353\237\274</span>\n                    </h3>\n\n                    <div className=\"space-y-2\">\n                      <FlavorBar label=\"\353\213\250\353\247\233 (Sweet)\" val={selectedEntry.flavors?.sweet ?? 0} max={5} />\n                      <FlavorBar label=\"\354\223\264\353\247\233 (Bitter)\" val={selectedEntry.flavors?.bitter ?? 0} max={5} />\n                      <FlavorBar label=\"\354\213\240\353\247\233 (Sour)\" val={selectedEntry.flavors?.sour ?? 0} max={5} />\n                      <FlavorBar label=\"\353\260\224\353\224\224\352\260\220 (Body)\" val={selectedEntry.flavors?.body ?? 0} max={5} />\n                      <FlavorBar label=\"\354\212\244\353\252\250\355\202\244\355\225\250\" val={selectedEntry.flavors?.smoky ?? 0} max={5} />\n                    </div>\n                  </div>\n\n                  {/* Detailed Tasting Memo */}\n                  <div className=\"bg-neutral-900/80 border border-amber-950/40 rounded-2xl p-3.5 space-y-2.5 shadow-md\">\n                    <h3 className=\"text-[10px] font-bold text-amber-400 uppercase tracking-wider\">\354\203\201\354\204\270 \354\213\234\354\235\214\355\217\211</h3>\n                    <p className=\"text-amber-200/85 text-[11px] leading-relaxed whitespace-pre-wrap\">\n                      {selectedEntry.notes || \"\352\270\260\353\241\235\353\220\234 \354\204\270\353\266\200 \355\205\214\354\235\264\354\212\244\355\214\205 \353\251\224\353\252\250\352\260\200 \354\227\206\354\212\265\353\213\210\353\213\244.\"}\n                    </p>\n                  </div>\n                </div>\n              </motion.div>\n            )}\n          </AnimatePresence>\n\n          {/* Simulated Android System Navigation Bar at bottom */}\n          <div className=\"h-10 bg-neutral-950 border-t border-neutral-900 flex items-center justify-around text-neutral-600 shrink-0 select-none z-40\">\n            {/* Back button */}\n            <button \n              onClick={() => {\n                if (currentScreen !== \'home\') {\n                  onScreenChange(\'home\');\n                }\n              }}\n              className=\"p-2 text-neutral-600 hover:text-amber-500/80 transition-colors\"\n            >\n              <div className=\"w-3.5 h-3.5 border-l-2 border-b-2 border-current rotate-45 transform translate-x-0.5\"></div>\n            </button>\n            {/* Home button */}\n            <button \n              onClick={() => onScreenChange(\'home\')}\n              className=\"p-2 text-neutral-600 hover:text-amber-500/80 transition-colors\"\n            >\n              <div className=\"w-3.5 h-3.5 rounded-full border-2 border-current\"></div>\n            </button>\n            {/* App overview square */}\n            <button className=\"p-2 text-neutral-600\">\n              <div className=\"w-3.5 h-3.5 border-2 border-current rounded-sm\"></div>\n            </button>\n          </div>\n\n        </div>\n      </div>\n    </div>\n  );\n}\n\n// Sub-component: FlavorBar\ninterface FlavorBarProps {\n  label: string;\n  val: number;\n  max: number;\n}\n\nfunction FlavorBar({ label, val, max }: FlavorBarProps) {\n  return (\n    <div className=\"space-y-1\">\n      <div className=\"flex justify-between items-center text-[10px]\">\n        <span className=\"text-amber-200/70\">{label}</span>\n        <span className=\"font-bold text-amber-400\">{val} / {max}</span>\n      </div>\n      <div className=\"w-full bg-neutral-950 h-2 rounded-full overflow-hidden border border-amber-950/20\">\n        <motion.div \n          className=\"bg-amber-500 h-full rounded-full\"\n          initial={{ width: 0 }}\n          animate={{ width: `${(val / max) * 100}%` }}\n          transition={{ duration: 0.6, ease: \"easeOut\" }}\n        />\n      </div>\n    </div>\n  );\n}\n"
