          text: "* **\354\236\204\354\235\230\354\240\201\354\235\270 \355\205\214\353\247\210 \355\214\214\352\264\264 \352\270\210\354\247\200**: \352\270\260\352\273\217 \352\265\254\354\204\261\355\225\264 \353\221\224 \354\204\270\353\240\250\353\220\234 \352\263\240\353\214\200\353\271\204 Slate & Amber \354\241\260\355\225\251\354\235\230 \355\206\244\354\225\244\353\247\244\353\204\210\353\245\274 \352\271\250\355\212\270\353\246\254\352\261\260\353\202\230 \355\235\224\355\225\234 \353\263\264\353\235\274\354\203\211/\352\267\270\353\235\274\353\215\260\354\235\264\354\205\230 \355\205\234\355\224\214\353\246\277 \355\230\225\355\203\234\353\241\234 \355\232\214\352\267\200\355\225\230\354\247\200 \353\247\210\354\213\255\354\213\234\354\230\244."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "* **\354\213\234\354\212\244\355\205\234 \353\241\234\352\271\205/\352\270\260\352\263\204 \353\215\260\354\235\264\355\204\260 \354\266\224\352\260\200 \354\236\220\354\240\234**: UI \354\227\254\353\260\261\354\235\264\353\202\230 \352\260\200\353\221\220\353\246\254\354\227\220 \353\266\210\355\225\204\354\232\224\355\225\234 \354\213\234\354\212\244\355\205\234 \353\251\224\355\203\200\353\215\260\354\235\264\355\204\260, \353\241\234\352\267\270 \354\266\234\353\240\245, \354\213\234\353\256\254\353\240\210\354\235\264\354\205\230 \355\225\221 \354\203\201\355\203\234(\354\230\210: `\342\227\217 SYSTEM LIVE`, `PORT: 3000`)\353\245\274 \354\247\200\354\240\200\353\266\204\355\225\230\352\262\214 \354\266\224\352\260\200\355\225\264 \354\243\274\353\212\224 \"\352\270\260\354\210\240 \354\213\234\353\212\211(Tech-Larping)\"\354\235\200 \354\262\240\354\240\200\355\236\210 \353\260\260\354\240\234\355\225\230\352\263\240, \352\271\224\353\201\224\355\225\234 \354\202\254\354\232\251\354\236\220 \355\231\230\352\262\275\354\235\204 \354\231\204\354\204\261\355\225\230\354\213\255\354\213\234\354\230\244."
          type: UNIFIED_DIFF_LINE_TYPE_INSERT
        }
        lines {
          text: "* **\354\202\254\354\232\251\354\236\220 \354\235\230\353\217\204 \354\264\210\352\263\274 \352\265\254\355\230\204 \352\270\210\354\247\200**: \354\202\254\354\232\251\354\236\220\352\260\200 \354\232\224\354\262\255\355\225\234 \354\212\244\354\275\224\355\224\204 \354\225\210\354\227\220\354\204\234\353\247\214 \354\240\225\352\265\220\355\225\230\352\263\240 \352\270\260\355\222\210 \354\236\210\353\212\224 \354\210\230\354\240\225\354\235\204 \352\260\200\355\225\230\352\263\240, \354\232\224\352\265\254\355\225\230\354\247\200 \354\225\212\354\235\200 \353\213\244\355\201\254\353\252\250\353\223\234 \355\206\240\352\270\200 \354\212\244\354\234\204\354\271\230\353\202\230 \353\213\244\353\245\270 \353\263\264\354\241\260 \354\260\250\355\212\270 \353\223\261\354\235\230 \352\270\260\353\212\245\354\235\204 \353\247\210\354\235\214\353\214\200\353\241\234 \354\266\224\352\260\200\355\225\230\354\227\254 \353\263\274\353\245\250\354\235\204 \353\212\230\353\246\254\354\247\200 \353\247\210\354\213\255\354\213\234\354\230\244. \354\236\245\354\235\270 \354\240\225\354\213\240\354\235\200 \352\270\260\353\212\245\354\235\230 \354\226\221\354\235\264 \354\225\204\353\213\214 \353\247\210\352\260\220\354\235\230 \355\200\204\353\246\254\355\213\260\354\227\220\354\204\234 \353\202\230\354\230\265\353\213\210\353\213\244."
