          text: "  * \354\273\264\355\217\254\354\240\200\353\270\224 \353\202\264\354\227\220\354\204\234 \354\247\201\354\240\221 \354\203\201\355\203\234\353\245\274 \354\241\260\354\236\221\355\225\230\354\247\200 \354\225\212\352\263\240, \354\203\201\355\203\234 \355\230\270\354\235\264\354\212\244\355\214\205(State Hoisting) \352\270\260\353\262\225\354\235\204 \354\202\254\354\232\251\355\225\230\354\227\254 \354\203\201\355\203\234(`remember { mutableStateOf(...) }`)\354\231\200 \354\235\264\353\262\244\355\212\270 \354\275\234\353\260\261(`onValueChange`, `onClick`)\354\235\204 \352\271\224\353\201\224\355\236\210 \353\266\204\353\246\254\355\225\251\353\213\210\353\213\244."
