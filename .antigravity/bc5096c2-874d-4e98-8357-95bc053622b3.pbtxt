        }
        lines {
          text: "  * \354\231\274\354\252\275\354\227\220\353\212\224 \354\213\244\354\240\234 \354\236\221\353\217\231\354\235\204 \354\213\234\352\260\201\355\231\224\355\225\230\353\212\224 \353\252\250\353\260\224\354\235\274 \355\230\225\355\203\234\354\235\230 **Phone Simulator (React)**\352\260\200 \355\203\221\354\236\254\353\220\230\354\226\264 \354\236\210\352\263\240, \354\230\244\353\245\270\354\252\275\354\227\220\353\212\224 \354\235\264\354\227\220 \353\217\231\352\270\260\355\231\224\353\220\230\353\212\224 **Code Viewer (Kotlin)**\352\260\200 \353\260\260\354\271\230\353\220\230\354\226\264 \354\236\210\354\212\265\353\213\210\353\213\244."
