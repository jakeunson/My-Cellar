        lines {
          text: "* **\354\213\234\354\212\244\355\205\234 \353\241\234\352\271\205/\352\270\260\352\263\204 \353\215\260\354\235\264\355\204\260 \354\266\224\352\260\200 \354\236\220\354\240\234**: UI \354\227\254\353\260\261\354\235\264\353\202\230 \352\260\200\353\221\220\353\246\254\354\227\220 \353\266\210\355\225\204\354\232\224\355\225\234 \354\213\234\354\212\244\355\205\234 \353\251\224\355\203\200\353\215\260\354\235\264\355\204\260, \353\241\234\352\267\270 \354\266\234\353\240\245, \354\213\234\353\256\254\353\240\210\354\235\264\354\205\230 \355\225\221 \354\203\201\355\203\234(\354\230\210: `\342\227\217 SYSTEM LIVE`, `PORT: 3000`)\353\245\274 \354\247\200\354\240\200\353\266\204\355\225\230\352\262\214 \354\266\224\352\260\200\355\225\264 \354\243\274\353\212\224 \"\352\270\260\354\210\240 \354\213\234\353\212\211(Tech-Larping)\"\354\235\200 \354\262\240\354\240\200\355\236\210 \353\260\260\354\240\234\355\225\230\352\263\240, \352\271\224\353\201\224\355\225\234 \354\202\254\354\232\251\354\236\220 \355\231\230\352\262\275\354\235\204 \354\231\204\354\204\261\355\225\230\354\213\255\354\213\234\354\230\244."
